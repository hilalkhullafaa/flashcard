  "conversations": [
    {
      "id": "ch11_conv01",
      "chapterId": 11,
      "order": 1,
      "title": "Percakapan 1 — Meminta Tolong",
      "turns": [
        { "speaker": "ミラー", "japanese": "すみません、ちょっと てつだって いただけませんか。", "romaji": "Sumimasen, chotto tetsudatte itadakemasen ka.", "indonesian": "Permisi, bisakah Anda membantu sebentar?" },
        { "speaker": "やまだ", "japanese": "はい、いいですよ。なんですか。", "romaji": "Hai, ii desu yo. Nan desu ka.", "indonesian": "Ya, boleh. Ada apa?" },
        { "speaker": "ミラー", "japanese": "この かんじを よんで ください。", "romaji": "Kono kanji o yonde kudasai.", "indonesian": "Tolong bacakan kanji ini." },
        { "speaker": "やまだ", "japanese": "「でんしゃ」と よみます。「電車」ですよ。", "romaji": "\"Densha\" to yomimasu. \"Densha\" desu yo.", "indonesian": "Dibaca \"densha\". Artinya kereta listrik." }
      ]
    },
    {
      "id": "ch11_conv02",
      "chapterId": 11,
      "order": 2,
      "title": "Percakapan 2 — Izin dan Larangan",
      "turns": [
        { "speaker": "ミラー", "japanese": "すみません、ここで たばこを すっても いいですか。", "romaji": "Sumimasen, koko de tabako o sutte mo ii desu ka.", "indonesian": "Permisi, bolehkah merokok di sini?" },
        { "speaker": "てんいん", "japanese": "すみません、ここは きんえんです。そとで すって ください。", "romaji": "Sumimasen, koko wa kin'en desu. Soto de sutte kudasai.", "indonesian": "Maaf, di sini dilarang merokok. Tolong merokok di luar." },
        { "speaker": "ミラー", "japanese": "わかりました。しゃしんは とっても いいですか。", "romaji": "Wakarimashita. Shashin wa totte mo ii desu ka.", "indonesian": "Mengerti. Bolehkah mengambil foto?" },
        { "speaker": "てんいん", "japanese": "はい、どうぞ。", "romaji": "Hai, douzo.", "indonesian": "Ya, silakan." }
      ]
    }
  ],
  "patterns": [
    {
      "id": "ch11_p01",
      "chapterId": 11,
      "order": 1,
      "pattern": "V て ください",
      "explanation": "Pola untuk membuat permintaan sopan. Bentuk te dari verba ditambah ください (kudasai) berarti 'tolong lakukan V'. Digunakan untuk meminta seseorang melakukan sesuatu dengan sopan.",
      "examples": [
        { "japanese": "ゆっくり はなして ください。", "romaji": "Yukkuri hanashite kudasai.", "indonesian": "Tolong berbicara perlahan-lahan." },
        { "japanese": "もう いちど いって ください。", "romaji": "Mou ichido itte kudasai.", "indonesian": "Tolong katakan sekali lagi." },
        { "japanese": "ここに なまえを かいて ください。", "romaji": "Koko ni namae o kaite kudasai.", "indonesian": "Tolong tulis nama di sini." }
      ]
    },
    {
      "id": "ch11_p02",
      "chapterId": 11,
      "order": 2,
      "pattern": "V て も いいですか",
      "explanation": "Pola untuk meminta izin melakukan sesuatu. Bentuk te dari verba ditambah もいいですか (mo ii desu ka) berarti 'bolehkah saya V?'. Untuk menjawab ya, gunakan いいですよ; untuk menolak, gunakan だめです atau ちょっと….",
      "examples": [
