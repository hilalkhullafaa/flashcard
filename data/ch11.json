  "grammar": [
    {
      "id": "ch11_g01",
      "chapterId": 11,
      "order": 1,
      "title": "Bentuk Te (て形) — Penghubung Verba",
      "explanation": "Bentuk te adalah bentuk dasar yang digunakan untuk menghubungkan verba dan membentuk berbagai pola gramatikal. Cara pembentukannya berbeda berdasarkan kelompok verba: Verba Kelompok 1 (verba-i): ～きます→いて, ～ぎます→いで, ～します→して, ～ちます/ります/います→って, ～にます/びます/みます→んで. Verba Kelompok 2 (verba-ru): ganti ます dengan て. Verba Kelompok 3 (ireguler): します→して, きます→きて.",
      "examples": [
        { "japanese": "かきます → かいて", "romaji": "kakimasu → kaite", "indonesian": "menulis → (bentuk te)" },
        { "japanese": "たべます → たべて", "romaji": "tabemasu → tabete", "indonesian": "makan → (bentuk te)" },
        { "japanese": "きます → きて", "romaji": "kimasu → kite", "indonesian": "datang → (bentuk te)" }
      ]
    },
    {
      "id": "ch11_g02",
      "chapterId": 11,
      "order": 2,
      "title": "Meminta Izin: 〜てもいいですか",
      "explanation": "Pola 〜てもいいですか digunakan untuk meminta izin melakukan sesuatu. Untuk menjawab dengan mengizinkan, gunakan いいですよ (boleh saja) atau はい、どうぞ (ya, silakan). Untuk menolak dengan sopan, gunakan ちょっと… (agak susah…) atau すみません、ちょっと… yang mengisyaratkan penolakan halus. だめです digunakan untuk penolakan tegas.",
      "examples": [
        { "japanese": "まどを あけても いいですか。 — いいですよ。", "romaji": "Mado o akete mo ii desu ka. — Ii desu yo.", "indonesian": "Bolehkah saya membuka jendela? — Boleh saja." },
        { "japanese": "ここで たべても いいですか。 — すみません、ちょっと…。", "romaji": "Koko de tabete mo ii desu ka. — Sumimasen, chotto...", "indonesian": "Bolehkah saya makan di sini? — Maaf, agak susah..." }
      ]
    },
    {
      "id": "ch11_g03",
      "chapterId": 11,
      "order": 3,
      "title": "Larangan: 〜てはいけません",
      "explanation": "Pola 〜てはいけません digunakan untuk menyatakan larangan yang tegas. Bentuk ini lebih kuat dari だめです dan sering digunakan dalam aturan, peraturan, atau instruksi resmi. Dalam percakapan sehari-hari yang lebih santai, だめです atau ～ないでください juga dapat digunakan untuk larangan yang lebih ringan.",
      "examples": [
        { "japanese": "ここで しゃしんを とっては いけません。", "romaji": "Koko de shashin o totte wa ikemasen.", "indonesian": "Tidak boleh mengambil foto di sini." },
