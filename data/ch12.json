  "patterns": [
    {
      "id": "ch12_p01",
      "chapterId": 12,
      "order": 1,
      "pattern": "V ています",
      "explanation": "Pola 〜ています memiliki dua fungsi utama: (1) menyatakan keadaan yang sedang berlangsung (progressive), seperti 'sedang makan'; (2) menyatakan hasil dari suatu tindakan yang masih berlanjut (resultant state), seperti 'sudah menikah' atau 'tinggal di'. Pilihan makna tergantung pada jenis verbanya.",
      "examples": [
        { "japanese": "いま ごはんを たべています。", "romaji": "Ima gohan o tabete imasu.", "indonesian": "Sekarang sedang makan." },
        { "japanese": "やまださんは けっこんしています。", "romaji": "Yamada-san wa kekkon shite imasu.", "indonesian": "Tuan Yamada sudah menikah." },
        { "japanese": "とうきょうに すんでいます。", "romaji": "Toukyou ni sunde imasu.", "indonesian": "Tinggal di Tokyo." }
      ]
    },
    {
      "id": "ch12_p02",
      "chapterId": 12,
      "order": 2,
      "pattern": "N を V ています",
      "explanation": "Pola ini digunakan untuk menyatakan bahwa seseorang sedang memakai atau membawa sesuatu. Partikel を menandai benda yang dipakai/dibawa. Sering digunakan untuk mendeskripsikan penampilan seseorang.",
      "examples": [
        { "japanese": "あおい シャツを きています。", "romaji": "Aoi shatsu o kite imasu.", "indonesian": "Sedang memakai kemeja biru." },
        { "japanese": "めがねを かけています。", "romaji": "Megane o kakete imasu.", "indonesian": "Sedang memakai kacamata." },
        { "japanese": "かばんを もっています。", "romaji": "Kaban o motte imasu.", "indonesian": "Sedang membawa tas." }
      ]
    },
    {
      "id": "ch12_p03",
      "chapterId": 12,
      "order": 3,
      "pattern": "N に すんでいます",
      "explanation": "Pola khusus untuk menyatakan tempat tinggal. すんでいます (sunde imasu) adalah bentuk 〜ています dari すみます (sumimasu — tinggal). Partikel に menandai lokasi tempat tinggal. Ini adalah contoh resultant state karena menggambarkan kondisi yang berlangsung terus.",
      "examples": [
        { "japanese": "おおさかに すんでいます。", "romaji": "Oosaka ni sunde imasu.", "indonesian": "Tinggal di Osaka." },
        { "japanese": "どこに すんでいますか。", "romaji": "Doko ni sunde imasu ka.", "indonesian": "Tinggal di mana?" },
        { "japanese": "とうきょうの ちかくに すんでいます。", "romaji": "Toukyou no chikaku ni sunde imasu.", "indonesian": "Tinggal di dekat Tokyo." }
      ]
    }
  ],
  "grammar": [
    {
      "id": "ch12_g01",
      "chapterId": 12,
      "order": 1,
      "title": "Bentuk 〜ています — Keadaan Sedang Berlangsung",
      "explanation": "Ketika 〜ています digunakan dengan verba aksi (action verbs), maknanya adalah keadaan yang sedang berlangsung saat ini (progressive aspect). Ini setara dengan '-ing' dalam bahasa Inggris. Contoh verba aksi: たべます (makan), よみます (membaca), はたらきます (bekerja). Untuk menyatakan 'tidak sedang', gunakan 〜ていません.",
      "examples": [
        { "japanese": "いま ほんを よんでいます。", "romaji": "Ima hon o yonde imasu.", "indonesian": "Sekarang sedang membaca buku." },
        { "japanese": "かいしゃで はたらいています。", "romaji": "Kaisha de hataraite imasu.", "indonesian": "Sedang bekerja di perusahaan." }
      ]
    },
    {
      "id": "ch12_g02",
      "chapterId": 12,
      "order": 2,
      "title": "Bentuk 〜ています — Hasil Keadaan",
      "explanation": "Ketika 〜ています digunakan dengan verba yang menyatakan perubahan keadaan (change-of-state verbs), maknanya adalah hasil dari tindakan tersebut yang masih berlanjut. Contoh: けっこんしています (sudah menikah = hasil dari menikah), きています (sedang memakai = hasil dari memakai), しっています (tahu = hasil dari mengetahui). Keadaan ini tidak menekankan proses, melainkan kondisi yang ada sekarang.",
      "examples": [
        { "japanese": "やまださんは けっこんしています。", "romaji": "Yamada-san wa kekkon shite imasu.", "indonesian": "Tuan Yamada sudah menikah." },
        { "japanese": "スーツを きています。", "romaji": "Suutsu o kite imasu.", "indonesian": "Sedang memakai setelan jas." }
      ]
    },
    {
      "id": "ch12_g03",
      "chapterId": 12,
      "order": 3,
      "title": "しっています vs しりません",
      "explanation": "Verba しります (shiru — mengetahui) memiliki penggunaan khusus dalam bahasa Jepang. Untuk menyatakan 'tahu', gunakan bentuk 〜ています: しっています (shitte imasu). Namun untuk menyatakan 'tidak tahu', JANGAN gunakan しっていません — gunakan しりません (shirimasen) langsung. Ini adalah pengecualian penting yang harus diingat.",
      "examples": [
        { "japanese": "やまださんを しっていますか。", "romaji": "Yamada-san o shitte imasu ka.", "indonesian": "Apakah Anda mengenal Tuan Yamada?" },
        { "japanese": "はい、しっています。／いいえ、しりません。", "romaji": "Hai, shitte imasu. / Iie, shirimasen.", "indonesian": "Ya, saya tahu. / Tidak, saya tidak tahu." }
      ]
    }
  ],
