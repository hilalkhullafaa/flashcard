  "conversations": [
    {
      "id": "ch07_conv01",
      "chapterId": 7,
      "order": 1,
      "title": "Percakapan 1 — Kegiatan Hari Minggu",
      "turns": [
        {
          "speaker": "やまだ",
          "japanese": "ミラーさんは 日曜日に なにを しますか。",
          "romaji": "Miraa-san wa nichiyoubi ni nani o shimasu ka.",
          "indonesian": "Tuan Miller, hari Minggu melakukan apa?",
          "hiragana": "ミラーさんは にちようびに なにを しますか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "友達と テニスを します。やまださんは？",
          "romaji": "Tomodachi to tenisu o shimasu. Yamada-san wa?",
          "indonesian": "Saya bermain tenis bersama teman. Yamada?",
          "hiragana": "ともだちと テニスを します。やまださんは？"
        },
        {
          "speaker": "やまだ",
          "japanese": "私は うちで 音楽を 木来ます。と木ど木 映画も 見ます。",
          "romaji": "Watashi wa uchi de ongaku o kikimasu. Tokidoki eiga mo mimasu.",
          "indonesian": "Saya mendengarkan musik di rumah. Kadang-kadang juga menonton film.",
          "hiragana": "わたしは うちで おんがくを ききます。ときどき えいがも みます。"
        }
      ]
    },
    {
      "id": "ch07_conv02",
