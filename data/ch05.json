  "patterns": [
    {
      "id": "ch05_p01",
      "chapterId": 5,
      "order": 1,
      "pattern": "N は N で いきます",
      "explanation": "Menyatakan pergi ke suatu tempat menggunakan alat transportasi tertentu. Partikel で (de) menandai alat/cara, partikel に (ni) menandai tujuan.",
      "examples": [
        { "japanese": "わたしは でんしゃで がっこうに いきます。", "romaji": "Watashi wa densha de gakkou ni ikimasu.", "indonesian": "Saya pergi ke sekolah dengan kereta." },
        { "japanese": "バスで えきに いきます。", "romaji": "Basu de eki ni ikimasu.", "indonesian": "Pergi ke stasiun dengan bus." }
      ]
    },
    {
      "id": "ch05_p02",
      "chapterId": 5,
      "order": 2,
      "pattern": "N に いきます/きます/かえります",
      "explanation": "Menyatakan arah pergerakan ke suatu tempat. Partikel に (ni) menandai tujuan atau arah. Digunakan dengan verba pergerakan いきます, きます, かえります.",
      "examples": [
        { "japanese": "にほんに きました。", "romaji": "Nihon ni kimashita.", "indonesian": "Saya datang ke Jepang." },
        { "japanese": "うちに かえります。", "romaji": "Uchi ni kaerimasu.", "indonesian": "Saya pulang ke rumah." }
      ]
    },
    {
      "id": "ch05_p03",
      "chapterId": 5,
      "order": 3,
      "pattern": "N と いきます",
      "explanation": "Menyatakan pergi bersama seseorang. Partikel と (to) berarti 'bersama' atau 'dan' ketika digunakan dengan orang.",
      "examples": [
        { "japanese": "ともだちと えいがを みに いきます。", "romaji": "Tomodachi to eiga o mi ni ikimasu.", "indonesian": "Saya pergi menonton film bersama teman." },
        { "japanese": "かぞくと にほんに いきました。", "romaji": "Kazoku to nihon ni ikimashita.", "indonesian": "Saya pergi ke Jepang bersama keluarga." }
      ]
    },
    {
      "id": "ch05_p04",
      "chapterId": 5,
      "order": 4,
      "pattern": "いつ N に いきますか",
      "explanation": "Menanyakan kapan seseorang pergi ke suatu tempat. いつ (itsu) berarti 'kapan'.",
      "examples": [
        { "japanese": "いつ にほんに きましたか。", "romaji": "Itsu nihon ni kimashita ka.", "indonesian": "Kapan Anda datang ke Jepang?" },
        { "japanese": "いつ うちに かえりますか。", "romaji": "Itsu uchi ni kaerimasu ka.", "indonesian": "Kapan Anda pulang ke rumah?" }
      ]
    }
  ],
  "grammar": [
    {
      "id": "ch05_g01",
      "chapterId": 5,
      "order": 1,
      "title": "Partikel で — Alat Transportasi",
      "explanation": "Partikel で (de) digunakan untuk menandai alat atau cara melakukan sesuatu. Dalam konteks transportasi, で menunjukkan kendaraan yang digunakan untuk bepergian. Pengecualian: berjalan kaki menggunakan ekspresi あるいて (aruite) tanpa partikel で.",
      "examples": [
        { "japanese": "でんしゃで がっこうに いきます。", "romaji": "Densha de gakkou ni ikimasu.", "indonesian": "Pergi ke sekolah dengan kereta." },
        { "japanese": "タクシーで びょういんに いきました。", "romaji": "Takushii de byouin ni ikimashita.", "indonesian": "Pergi ke rumah sakit dengan taksi." }
      ]
    },
    {
      "id": "ch05_g02",
      "chapterId": 5,
      "order": 2,
      "title": "Partikel に — Tujuan Pergerakan",
      "explanation": "Partikel に (ni) digunakan untuk menandai tujuan atau arah pergerakan ketika digunakan bersama verba pergerakan seperti いきます (pergi), きます (datang), dan かえります (pulang). Partikel に menunjukkan titik akhir dari pergerakan tersebut.",
      "examples": [
        { "japanese": "にほんに いきます。", "romaji": "Nihon ni ikimasu.", "indonesian": "Saya pergi ke Jepang." },
        { "japanese": "うちに かえります。", "romaji": "Uchi ni kaerimasu.", "indonesian": "Saya pulang ke rumah." }
      ]
    },
    {
      "id": "ch05_g03",
      "chapterId": 5,
      "order": 3,
      "title": "Partikel と — Bersama Seseorang",
      "explanation": "Partikel と (to) berarti 'bersama' ketika digunakan dengan orang. Pola 'Orang と いきます' menyatakan bahwa pembicara pergi bersama orang tersebut. と juga dapat berarti 'dan' untuk menghubungkan dua nomina.",
      "examples": [
        { "japanese": "ともだちと えきに いきます。", "romaji": "Tomodachi to eki ni ikimasu.", "indonesian": "Saya pergi ke stasiun bersama teman." },
        { "japanese": "かぞくと にほんに きました。", "romaji": "Kazoku to nihon ni kimashita.", "indonesian": "Saya datang ke Jepang bersama keluarga." }
      ]
    }
  ],
