  "conversations": [
    {
      "id": "ch05_conv01",
      "chapterId": 5,
      "order": 1,
      "title": "Percakapan 1 — Pergi ke Mana",
      "turns": [
        { "speaker": "やまだ", "japanese": "ミラーさん、きのう どこかへ いきましたか。", "romaji": "Miraa-san, kinou doko ka e ikimashita ka.", "indonesian": "Tuan Miller, kemarin pergi ke mana?" },
        { "speaker": "ミラー", "japanese": "はい、ともだちと きょうとへ いきました。", "romaji": "Hai, tomodachi to Kyouto e ikimashita.", "indonesian": "Ya, saya pergi ke Kyoto bersama teman." },
        { "speaker": "やまだ", "japanese": "なんで いきましたか。", "romaji": "Nan de ikimashita ka.", "indonesian": "Naik apa?" },
        { "speaker": "ミラー", "japanese": "しんかんせんで いきました。", "romaji": "Shinkansen de ikimashita.", "indonesian": "Naik Shinkansen." }
      ]
    },
    {
      "id": "ch05_conv02",
      "chapterId": 5,
      "order": 2,
      "title": "Percakapan 2 — Rencana Liburan",
      "turns": [
        { "speaker": "カリナ", "japanese": "なつやすみに どこかへ いきますか。", "romaji": "Natsuyasumi ni doko ka e ikimasu ka.", "indonesian": "Apakah liburan musim panas pergi ke suatu tempat?" },
        { "speaker": "ミラー", "japanese": "はい、かぞくと ほっかいどうへ いきます。カリナさんは？", "romaji": "Hai, kazoku to Hokkaidou e ikimasu. Karina-san wa?", "indonesian": "Ya, saya pergi ke Hokkaido bersama keluarga. Karina?" },
        { "speaker": "カリナ", "japanese": "わたしは くにへ かえります。インドネシアへ ひこうきで かえります。", "romaji": "Watashi wa kuni e kaerimasu. Indoneshia e hikouki de kaerimasu.", "indonesian": "Saya pulang ke negara asal. Pulang ke Indonesia naik pesawat." }
      ]
    }
  ],
  "patterns": [
    {
      "id": "ch05_p01",
      "chapterId": 5,
      "order": 1,
      "pattern": "N は N で いきます",
      "explanation": "Menyatakan pergi ke suatu tempat menggunakan alat transportasi tertentu. Partikel で (de) menandai alat/cara, partikel に (ni) menandai tujuan.",
      "examples": [
        { "japanese": "わたしは でんしゃで がっこうに いきます。", "romaji": "Watashi wa densha de gakkou ni ikimasu.", "indonesian": "Saya pergi ke sekolah dengan kereta." },
        { "japanese": "バスで えきに いきます。", "romaji": "Basu de eki ni ikimasu.", "indonesian": "Pergi ke stasiun dengan bus." }
      ]
    },
    {
      "id": "ch05_p02",
