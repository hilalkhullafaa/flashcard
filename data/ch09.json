          "japanese": "やさいが す今日です。すか。",
          "romaji": "Yasai ga suki desu ka.",
          "indonesian": "Apakah suka sayuran?",
          "hiragana": "やさいが す今日です。すか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "いいえ、あまり す今日じゃありません。",
          "romaji": "Iie, amari suki ja arimasen.",
          "indonesian": "Tidak, tidak terlalu suka.",
          "hiragana": "いいえ、あまり す今日じゃありません。"
        }
      ]
    },
