  "conversations": [
    {
      "id": "ch09_conv01",
      "chapterId": 9,
      "order": 1,
      "title": "Percakapan 1 â€” Ulang Tahun",
      "turns": [
        {
          "speaker": "カリナ",
          "japanese": "ミラーさんの 誕生日は いい月です。すかすか。",
          "romaji": "Miraa-san, tanjoubi wa itsu desu ka.",
          "indonesian": "Tuan Miller, kapan ulang tahunnya?",
          "hiragana": "ミラーさんの 誕生日は いい月です。すかすか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "12月 25日です。す。カリナさんは？",
          "romaji": "Juunigatsu nijuugonichi desu. Karina-san wa?",
          "indonesian": "Tanggal 25 Desember. Karina?",
          "hiragana": "12月 25日です。す。カリナさんは？"
        },
        {
          "speaker": "カリナ",
          "japanese": "私は 8月 17日です。す。",
          "romaji": "Watashi wa hachigatsu juushichinichi desu.",
          "indonesian": "Saya tanggal 17 Agustus.",
          "hiragana": "わたしは 8が月 17日です。すす。"
        },
        {
          "speaker": "ミラー",
          "japanese": "そうです。すか。インドネシアの 独立記念日と 同じです。す年。",
          "romaji": "Sou desu ka. Indoneshia no dokuritsu kinenbi to onaji desu ne.",
          "indonesian": "Oh begitu. Sama dengan hari kemerdekaan Indonesia ya.",
          "hiragana": "そうです。すか。インドネシアの どくり月今日年ん誕生日と おなじです。す年。"
        }
      ]
    },
    {
      "id": "ch09_conv02",
      "chapterId": 9,
      "order": 2,
      "title": "Percakapan 2 â€” Merayakan Ulang Tahun",
      "turns": [
        {
          "speaker": "山田",
          "japanese": "ミラーさん、お誕生日おめです。とうございます。",
          "romaji": "Miraa-san, otanjoubi omedetou gozaimasu.",
          "indonesian": "Tuan Miller, selamat ulang tahun.",
          "hiragana": "ミラーさん、おたんじょう誕生日 おめです。とうございます。"
        },
        {
          "speaker": "ミラー",
          "japanese": "ありがとうございます",
          "romaji": "Arigatou gozaimasu.",
          "indonesian": "Terima kasih.",
          "hiragana": "ありがとうございます"
        },
        {
          "speaker": "山田",
          "japanese": "おいく月に なりましたか。",
          "romaji": "Oikutsu ni narimashita ka.",
          "indonesian": "Sudah berapa tahun?",
          "hiragana": "おいく月に なりましたか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "35歳に なりました。",
          "romaji": "Sanjuugosai ni narimashita.",
          "indonesian": "Sudah 35 tahun.",
          "hiragana": "35さいに なりました。"
        }
      ]
    },
    {
      "id": "ch09_conv03",
      "chapterId": 9,
      "order": 3,
      "title": "Percakapan 3 — Suka Olahraga",
      "turns": [
        {
          "speaker": "や山田",
          "japanese": "スポーツが す今日です。すか。",
          "romaji": "Supootsu ga suki desu ka.",
          "indonesian": "Apakah suka olahraga?",
          "hiragana": "スポーツが す今日です。すか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "はい、とても す今日です。す。",
          "romaji": "Hai, totemo suki desu.",
          "indonesian": "Ya, sangat suka.",
          "hiragana": "はい、とても す今日です。す。"
        }
      ]
    },
    {
      "id": "ch09_conv04",
      "chapterId": 9,
      "order": 4,
      "title": "Percakapan 4 — Tidak Suka Sayuran",
      "turns": [
        {
