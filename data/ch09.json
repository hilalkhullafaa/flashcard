  "conversations": [
    {
      "id": "ch09_conv01",
      "chapterId": 9,
      "order": 1,
      "title": "Percakapan 1 — Ulang Tahun",
      "turns": [
        { "speaker": "カリナ", "japanese": "ミラーさん、たんじょうびは いつですか。", "romaji": "Miraa-san, tanjoubi wa itsu desu ka.", "indonesian": "Tuan Miller, kapan ulang tahunnya?" },
        { "speaker": "ミラー", "japanese": "12がつ 25にちです。カリナさんは？", "romaji": "Juunigatsu nijuugonichi desu. Karina-san wa?", "indonesian": "Tanggal 25 Desember. Karina?" },
        { "speaker": "カリナ", "japanese": "わたしは 8がつ 17にちです。", "romaji": "Watashi wa hachigatsu juushichinichi desu.", "indonesian": "Saya tanggal 17 Agustus." },
        { "speaker": "ミラー", "japanese": "そうですか。インドネシアの どくりつきねんびと おなじですね。", "romaji": "Sou desu ka. Indoneshia no dokuritsu kinenbi to onaji desu ne.", "indonesian": "Oh begitu. Sama dengan hari kemerdekaan Indonesia ya." }
      ]
    },
    {
      "id": "ch09_conv02",
      "chapterId": 9,
      "order": 2,
      "title": "Percakapan 2 — Merayakan Ulang Tahun",
      "turns": [
        { "speaker": "やまだ", "japanese": "ミラーさん、おたんじょうびおめでとうございます。", "romaji": "Miraa-san, otanjoubi omedetou gozaimasu.", "indonesian": "Tuan Miller, selamat ulang tahun." },
        { "speaker": "ミラー", "japanese": "ありがとうございます。", "romaji": "Arigatou gozaimasu.", "indonesian": "Terima kasih." },
        { "speaker": "やまだ", "japanese": "おいくつに なりましたか。", "romaji": "Oikutsu ni narimashita ka.", "indonesian": "Sudah berapa tahun?" },
        { "speaker": "ミラー", "japanese": "35さいに なりました。", "romaji": "Sanjuugosai ni narimashita.", "indonesian": "Sudah 35 tahun." }
      ]
    }
  ],
  "grammar": [
    {
      "id": "ch09_g01",
      "chapterId": 9,
      "order": 1,
      "title": "Cara Menyebut Tanggal dalam Bahasa Jepang",
      "explanation": "Sebagian besar tanggal dibaca dengan angka + にち (nichi), namun banyak tanggal memiliki bacaan tidak beraturan yang harus dihafal. Tanggal 1 (ついたち), 2 (ふつか), 3 (みっか), 4 (よっか), 5 (いつか), 6 (むいか), 7 (なのか), 8 (ようか), 9 (ここのか), 10 (とおか), 14 (じゅうよっか), 20 (はつか), dan 24 (にじゅうよっか) semuanya memiliki bacaan khusus.",
      "examples": [
        { "japanese": "きょうは 4がつ ついたちです。", "romaji": "Kyou wa shigatsu tsuitachi desu.", "indonesian": "Hari ini tanggal 1 April." },
        { "japanese": "わたしの たんじょうびは 7がつ はつかです。", "romaji": "Watashi no tanjoubi wa shichigatsu hatsuka desu.", "indonesian": "Ulang tahun saya tanggal 20 Juli." }
      ]
    },
    {
      "id": "ch09_g02",
      "chapterId": 9,
      "order": 2,
      "title": "Cara Menyebut Bulan dalam Bahasa Jepang",
      "explanation": "Nama bulan dalam bahasa Jepang dibentuk dengan angka 1–12 ditambah sufiks 〜月 (gatsu). Tidak ada nama khusus seperti 'Januari' atau 'Februari' — cukup 1月 (ichigatsu), 2月 (nigatsu), dst. Perhatikan bahwa 4月 dibaca 'shigatsu' (bukan 'yongatsu'), 7月 dibaca 'shichigatsu', dan 9月 dibaca 'kugatsu'.",
      "examples": [
        { "japanese": "わたしの たんじょうびは 3がつです。", "romaji": "Watashi no tanjoubi wa sangatsu desu.", "indonesian": "Ulang tahun saya di bulan Maret." },
        { "japanese": "にほんの おしょうがつは 1がつです。", "romaji": "Nihon no oshougatsu wa ichigatsu desu.", "indonesian": "Tahun Baru Jepang ada di bulan Januari." }
      ]
    },
    {
      "id": "ch09_g03",
      "chapterId": 9,
      "order": 3,
      "title": "Urutan Penulisan Tanggal Lengkap",
      "explanation": "Dalam bahasa Jepang, urutan penulisan tanggal lengkap adalah dari yang terbesar ke terkecil: tahun (〜年) → bulan (〜月) → tanggal (〜日). Urutan ini berlawanan dengan bahasa Indonesia yang biasanya menulis tanggal → bulan → tahun. Saat membaca tanggal lengkap, selalu sebutkan tahun terlebih dahulu.",
      "examples": [
        { "japanese": "きょうは 2024ねん 4がつ 1にちです。", "romaji": "Kyou wa nisen nijuuyonen shigatsu tsuitachi desu.", "indonesian": "Hari ini tanggal 1 April 2024." },
        { "japanese": "わたしは 1990ねん 7がつ 20にちに うまれました。", "romaji": "Watashi wa senkyuuhyaku kyuujuunen shichigatsu hatsuka ni umaremashita.", "indonesian": "Saya lahir pada tanggal 20 Juli 1990." }
      ]
    }
  ],
  "patterns": [
    {
      "id": "ch09_p01",
      "chapterId": 9,
      "order": 1,
      "pattern": "たんじょうびは いつですか",
      "explanation": "Pola untuk menanyakan kapan ulang tahun seseorang. いつ (itsu) berarti 'kapan'. Dapat juga digunakan untuk menanyakan tanggal acara lainnya.",
      "examples": [
        { "japanese": "たんじょうびは いつですか。", "romaji": "Tanjoubi wa itsu desu ka.", "indonesian": "Kapan ulang tahun Anda?" },
        { "japanese": "パーティーは いつですか。", "romaji": "Paatii wa itsu desu ka.", "indonesian": "Kapan pestanya?" }
      ]
    },
    {
      "id": "ch09_p02",
      "chapterId": 9,
      "order": 2,
      "pattern": "N は N がつ N にちです",
      "explanation": "Pola untuk menyatakan tanggal suatu kejadian. がつ (gatsu) untuk bulan dan にち (nichi) untuk tanggal. Beberapa tanggal memiliki bacaan tidak beraturan seperti ついたち (tanggal 1) dan はつか (tanggal 20).",
      "examples": [
        { "japanese": "わたしの たんじょうびは 3がつ 15にちです。", "romaji": "Watashi no tanjoubi wa sangatsu juugonichi desu.", "indonesian": "Ulang tahun saya tanggal 15 Maret." },
        { "japanese": "きょうは 4がつ ついたちです。", "romaji": "Kyou wa shigatsu tsuitachi desu.", "indonesian": "Hari ini tanggal 1 April." }
      ]
    },
    {
      "id": "ch09_p03",
      "chapterId": 9,
      "order": 3,
      "pattern": "N ねん N がつ N にち",
      "explanation": "Pola untuk menyatakan tanggal lengkap dengan tahun, bulan, dan tanggal. Urutan penulisan dalam bahasa Jepang adalah tahun → bulan → tanggal (kebalikan dari bahasa Indonesia).",
      "examples": [
        { "japanese": "きょうは 2024ねん 4がつ 1にちです。", "romaji": "Kyou wa nisen nijuuyonen shigatsu tsuitachi desu.", "indonesian": "Hari ini tanggal 1 April 2024." },
        { "japanese": "わたしは 1990ねん 7がつ 20にちに うまれました。", "romaji": "Watashi wa senkyuuhyaku kyuujuunen shichigatsu hatsuka ni umaremashita.", "indonesian": "Saya lahir pada tanggal 20 Juli 1990." }
      ]
    }
  ],
