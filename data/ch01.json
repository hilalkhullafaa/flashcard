  "patterns": [
    {
      "id": "ch01_p01",
      "chapterId": 1,
      "order": 1,
      "pattern": "N は N です",
      "explanation": "Menyatakan identitas atau profesi seseorang. Partikel は (wa) menandai subjek, です (desu) adalah kopula sopan.",
      "examples": [
        { "japanese": "わたしは マイク・ミラーです。", "romaji": "Watashi wa Maiku Miraa desu.", "indonesian": "Saya adalah Mike Miller." },
        { "japanese": "サントスさんは がくせいです。", "romaji": "Santosu-san wa gakusei desu.", "indonesian": "Santos adalah pelajar." }
      ]
    },
    {
      "id": "ch01_p02",
      "chapterId": 1,
      "order": 2,
      "pattern": "N は N では ありません",
      "explanation": "Menyangkal identitas atau profesi. では ありません (dewa arimasen) adalah bentuk negatif sopan dari です.",
      "examples": [
        { "japanese": "わたしは がくせいでは ありません。", "romaji": "Watashi wa gakusei dewa arimasen.", "indonesian": "Saya bukan pelajar." },
        { "japanese": "ミラーさんは せんせいでは ありません。", "romaji": "Miraa-san wa sensei dewa arimasen.", "indonesian": "Tuan Miller bukan guru." }
      ]
    },
    {
      "id": "ch01_p03",
      "chapterId": 1,
      "order": 3,
      "pattern": "N は N ですか",
      "explanation": "Pertanyaan untuk menanyakan identitas atau profesi. Partikel か (ka) di akhir kalimat menandai kalimat tanya.",
      "examples": [
        { "japanese": "ミラーさんは がくせいですか。", "romaji": "Miraa-san wa gakusei desu ka.", "indonesian": "Apakah Tuan Miller pelajar?" },
        { "japanese": "あのひとは せんせいですか。", "romaji": "Ano hito wa sensei desu ka.", "indonesian": "Apakah orang itu guru?" }
      ]
    },
    {
      "id": "ch01_p04",
      "chapterId": 1,
      "order": 4,
      "pattern": "N も N です",
      "explanation": "Menyatakan kesamaan dengan subjek sebelumnya. Partikel も (mo) berarti 'juga', menggantikan partikel は.",
      "examples": [
        { "japanese": "サントスさんも がくせいです。", "romaji": "Santosu-san mo gakusei desu.", "indonesian": "Santos juga pelajar." },
        { "japanese": "わたしも エンジニアです。", "romaji": "Watashi mo enjinia desu.", "indonesian": "Saya juga insinyur." }
      ]
    }
  ],
  "grammar": [
    {
      "id": "ch01_g01",
      "chapterId": 1,
      "order": 1,
      "title": "Partikel は (wa) — Penanda Topik",
      "explanation": "Partikel は (dibaca 'wa') menandai topik kalimat. Topik adalah hal yang sedang dibicarakan. Berbeda dengan subjek gramatikal, topik bisa berupa subjek, objek, atau elemen lain yang ingin ditonjolkan pembicara.",
      "examples": [
        { "japanese": "わたしは がくせいです。", "romaji": "Watashi wa gakusei desu.", "indonesian": "Saya adalah pelajar." },
        { "japanese": "ミラーさんは エンジニアです。", "romaji": "Miraa-san wa enjinia desu.", "indonesian": "Tuan Miller adalah insinyur." }
      ]
    },
    {
      "id": "ch01_g02",
      "chapterId": 1,
      "order": 2,
      "title": "Pola です / では ありません",
      "explanation": "です (desu) adalah kopula sopan yang berarti 'adalah'. Bentuk negatifnya adalah では ありません (dewa arimasen) yang berarti 'bukan'. Dalam percakapan sehari-hari, では sering disingkat menjadi じゃ.",
      "examples": [
        { "japanese": "これは じしょです。", "romaji": "Kore wa jisho desu.", "indonesian": "Ini adalah kamus." },
        { "japanese": "わたしは せんせいでは ありません。", "romaji": "Watashi wa sensei dewa arimasen.", "indonesian": "Saya bukan guru." }
      ]
    },
    {
      "id": "ch01_g03",
      "chapterId": 1,
      "order": 3,
      "title": "Partikel も (mo) — Juga/Pun",
      "explanation": "Partikel も (mo) berarti 'juga' atau 'pun'. Partikel ini menggantikan partikel は untuk menyatakan bahwa sesuatu yang sama berlaku untuk topik baru. Jika dua hal memiliki sifat yang sama, も digunakan untuk keduanya.",
      "examples": [
        { "japanese": "サントスさんも がくせいです。", "romaji": "Santosu-san mo gakusei desu.", "indonesian": "Santos juga pelajar." },
        { "japanese": "わたしも にほんじんでは ありません。", "romaji": "Watashi mo nihonjin dewa arimasen.", "indonesian": "Saya juga bukan orang Jepang." }
      ]
    }
  ],
