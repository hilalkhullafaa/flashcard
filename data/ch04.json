  "patterns": [
    {
      "id": "ch04_p01",
      "chapterId": 4,
      "order": 1,
      "pattern": "N は N じ N ふん に V",
      "explanation": "Menyatakan kegiatan yang dilakukan pada waktu tertentu. Partikel に (ni) menandai waktu spesifik kapan kegiatan dilakukan.",
      "examples": [
        { "japanese": "わたしは まいあさ 6じに おきます。", "romaji": "Watashi wa maiasa rokuji ni okimasu.", "indonesian": "Saya bangun jam 6 setiap pagi." },
        { "japanese": "じゅぎょうは 9じ30ぷんに はじまります。", "romaji": "Jugyou wa kuji sanjuppun ni hajimarimasu.", "indonesian": "Pelajaran dimulai pukul 9:30." }
      ]
    },
    {
      "id": "ch04_p02",
      "chapterId": 4,
      "order": 2,
      "pattern": "N から N まで",
      "explanation": "Menyatakan rentang waktu dari titik awal sampai titik akhir. から (kara) berarti 'dari', まで (made) berarti 'sampai'.",
      "examples": [
        { "japanese": "9じから 5じまで はたらきます。", "romaji": "Kuji kara goji made hatarakimasu.", "indonesian": "Bekerja dari jam 9 sampai jam 5." },
        { "japanese": "げつようびから きんようびまで べんきょうします。", "romaji": "Getsuyoubi kara kin'youbi made benkyou shimasu.", "indonesian": "Belajar dari hari Senin sampai hari Jumat." }
      ]
    },
    {
      "id": "ch04_p03",
      "chapterId": 4,
      "order": 3,
      "pattern": "N は なんじに V ますか",
      "explanation": "Menanyakan jam berapa seseorang melakukan suatu kegiatan. なんじ (nanji) berarti 'jam berapa'.",
      "examples": [
        { "japanese": "まいにち なんじに ねますか。", "romaji": "Mainichi nanji ni nemasu ka.", "indonesian": "Jam berapa Anda tidur setiap hari?" },
        { "japanese": "しごとは なんじに おわりますか。", "romaji": "Shigoto wa nanji ni owarimasu ka.", "indonesian": "Jam berapa pekerjaan selesai?" }
      ]
    }
  ],
  "grammar": [
    {
      "id": "ch04_g01",
      "chapterId": 4,
      "order": 1,
      "title": "Partikel に — Penanda Waktu Spesifik",
      "explanation": "Partikel に (ni) digunakan untuk menandai waktu spesifik kapan suatu kegiatan dilakukan. Waktu spesifik meliputi jam (〜時), hari dalam seminggu (〜曜日), tanggal, dan bulan. Namun, kata waktu relatif seperti きょう (hari ini), あした (besok), まいにち (setiap hari) tidak menggunakan partikel に.",
      "examples": [
        { "japanese": "7じに おきます。", "romaji": "Shichiji ni okimasu.", "indonesian": "Saya bangun jam 7." },
        { "japanese": "にちようびに やすみます。", "romaji": "Nichiyoubi ni yasumimasu.", "indonesian": "Saya libur pada hari Minggu." }
      ]
    },
    {
      "id": "ch04_g02",
      "chapterId": 4,
      "order": 2,
      "title": "Pola から〜まで — Rentang Waktu",
      "explanation": "Pola から〜まで digunakan untuk menyatakan rentang waktu. から (kara) berarti 'dari' atau 'mulai dari', dan まで (made) berarti 'sampai' atau 'hingga'. Keduanya dapat digunakan bersama atau sendiri-sendiri.",
      "examples": [
        { "japanese": "9じから 5じまで はたらきます。", "romaji": "Kuji kara goji made hatarakimasu.", "indonesian": "Bekerja dari jam 9 sampai jam 5." },
        { "japanese": "げつようびから きんようびまで がっこうが あります。", "romaji": "Getsuyoubi kara kin'youbi made gakkou ga arimasu.", "indonesian": "Ada sekolah dari hari Senin sampai Jumat." }
      ]
    },
    {
      "id": "ch04_g03",
      "chapterId": 4,
      "order": 3,
      "title": "Cara Membaca Jam dalam Bahasa Jepang",
      "explanation": "Jam dibaca dengan menambahkan 時 (ji) setelah angka, dan menit dengan 分 (fun/pun) setelah angka. Setengah jam dinyatakan dengan 半 (han). Pagi hari (AM) menggunakan 午前 (gozen) dan sore/malam (PM) menggunakan 午後 (gogo) yang diletakkan sebelum jam.",
      "examples": [
        { "japanese": "いまは ごぜん 9じ はんです。", "romaji": "Ima wa gozen kuji han desu.", "indonesian": "Sekarang pukul 9:30 pagi." },
        { "japanese": "ごご 3じ 15ふんに かいぎが あります。", "romaji": "Gogo sanji juugofun ni kaigi ga arimasu.", "indonesian": "Ada rapat pukul 3:15 sore." }
      ]
    }
  ],
