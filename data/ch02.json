  "patterns": [
    {
      "id": "ch02_p01",
      "chapterId": 2,
      "order": 1,
      "pattern": "これ/それ/あれ は N です",
      "explanation": "Menunjuk dan mengidentifikasi benda. これ untuk benda dekat pembicara, それ untuk benda dekat lawan bicara, あれ untuk benda jauh dari keduanya.",
      "examples": [
        { "japanese": "これは じしょです。", "romaji": "Kore wa jisho desu.", "indonesian": "Ini adalah kamus." },
        { "japanese": "あれは テレビです。", "romaji": "Are wa terebi desu.", "indonesian": "Itu adalah televisi." }
      ]
    },
    {
      "id": "ch02_p02",
      "chapterId": 2,
      "order": 2,
      "pattern": "この/その/あの N は N です",
      "explanation": "Modifikator penunjuk yang diikuti nomina. この/その/あの selalu diikuti nomina, berbeda dengan これ/それ/あれ yang berdiri sendiri.",
      "examples": [
        { "japanese": "この かばんは わたしのです。", "romaji": "Kono kaban wa watashi no desu.", "indonesian": "Tas ini milik saya." },
        { "japanese": "その ほんは にほんごのほんです。", "romaji": "Sono hon wa nihongo no hon desu.", "indonesian": "Buku itu adalah buku bahasa Jepang." }
      ]
    },
    {
      "id": "ch02_p03",
      "chapterId": 2,
      "order": 3,
      "pattern": "N は N の N です",
      "explanation": "Menyatakan kepemilikan atau asal benda. Partikel の (no) menghubungkan dua nomina, menyatakan 'milik' atau 'dari'.",
      "examples": [
        { "japanese": "これは にほんごの ほんです。", "romaji": "Kore wa nihongo no hon desu.", "indonesian": "Ini adalah buku bahasa Jepang." },
        { "japanese": "それは ミラーさんの かばんです。", "romaji": "Sore wa Miraa-san no kaban desu.", "indonesian": "Itu adalah tas Tuan Miller." }
      ]
    },
    {
      "id": "ch02_p04",
      "chapterId": 2,
      "order": 4,
      "pattern": "N は N ですか、N ですか",
      "explanation": "Pertanyaan pilihan (atau). Menanyakan apakah suatu benda adalah A atau B. Dijawab dengan menyebutkan salah satu pilihan.",
      "examples": [
        { "japanese": "それは じしょですか、ほんですか。", "romaji": "Sore wa jisho desu ka, hon desu ka.", "indonesian": "Apakah itu kamus atau buku?" },
        { "japanese": "これは えんぴつですか、ボールペンですか。", "romaji": "Kore wa enpitsu desu ka, boorupen desu ka.", "indonesian": "Apakah ini pensil atau pulpen?" }
      ]
    }
  ],
  "grammar": [
    {
      "id": "ch02_g01",
      "chapterId": 2,
      "order": 1,
      "title": "Kata Tunjuk これ・それ・あれ (Ko-So-A-Do)",
      "explanation": "Bahasa Jepang memiliki sistem kata tunjuk Ko-So-A-Do berdasarkan jarak. これ (kore) untuk benda dekat pembicara, それ (sore) untuk benda dekat lawan bicara, あれ (are) untuk benda jauh dari keduanya, dan どれ (dore) untuk menanyakan 'yang mana'. Sistem ini juga berlaku untuk modifikator この/その/あの/どの yang selalu diikuti nomina.",
      "examples": [
        { "japanese": "これは わたしの ほんです。", "romaji": "Kore wa watashi no hon desu.", "indonesian": "Ini adalah buku saya." },
        { "japanese": "あれは なんですか。", "romaji": "Are wa nan desu ka.", "indonesian": "Itu apa?" }
      ]
    },
    {
      "id": "ch02_g02",
      "chapterId": 2,
      "order": 2,
      "title": "Partikel の (no) — Kepemilikan dan Modifikasi",
      "explanation": "Partikel の (no) menghubungkan dua nomina. Fungsi utamanya adalah menyatakan kepemilikan (A の B = B milik A) atau modifikasi (A の B = B yang berhubungan dengan A). Partikel の juga dapat berdiri sendiri di akhir kalimat menggantikan nomina yang sudah diketahui konteksnya.",
      "examples": [
        { "japanese": "これは ミラーさんの かばんです。", "romaji": "Kore wa Miraa-san no kaban desu.", "indonesian": "Ini adalah tas Tuan Miller." },
        { "japanese": "この かさは だれのですか。", "romaji": "Kono kasa wa dare no desu ka.", "indonesian": "Payung ini milik siapa?" }
      ]
    },
    {
      "id": "ch02_g03",
      "chapterId": 2,
      "order": 3,
      "title": "Pertanyaan Pilihan: A ですか、B ですか",
      "explanation": "Untuk menanyakan pilihan antara dua kemungkinan, gunakan pola 'A ですか、B ですか'. Pola ini meminta lawan bicara memilih salah satu dari dua opsi yang disebutkan. Jawaban cukup menyebutkan pilihan yang benar diikuti です.",
      "examples": [
        { "japanese": "それは じしょですか、ほんですか。", "romaji": "Sore wa jisho desu ka, hon desu ka.", "indonesian": "Apakah itu kamus atau buku?" },
        { "japanese": "おくには インドネシアですか、マレーシアですか。", "romaji": "Okuni wa Indoneshia desu ka, Mereeshia desu ka.", "indonesian": "Negara asal Anda Indonesia atau Malaysia?" }
      ]
    }
  ],
