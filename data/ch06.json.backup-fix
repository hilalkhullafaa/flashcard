  "grammar": [
    {
      "id": "ch06_g01",
      "chapterId": 6,
      "order": 1,
      "title": "Partikel を (wo) — Penanda Objek Langsung",
      "explanation": "Partikel を (dibaca 'o') digunakan untuk menandai objek langsung dari verba transitif — yaitu benda atau orang yang menerima aksi dari verba. Dalam bahasa Indonesia, objek langsung biasanya tidak memerlukan preposisi khusus.",
      "examples": [
        {
          "japanese": "私は まいあさ パンを たべます。",
          "romaji": "Watashi wa maiasa pan o tabemasu.",
          "indonesian": "Saya makan roti setiap pagi."
        },
        {
          "japanese": "コーヒーを のみます。",
          "romaji": "Koohii o nomimasu.",
          "indonesian": "Saya minum kopi."
        }
      ]
    },
    {
      "id": "ch06_g02",
      "chapterId": 6,
      "order": 2,
      "title": "Partikel で — Tempat Kegiatan",
      "explanation": "Partikel で menandai tempat di mana suatu kegiatan atau aktivitas dilakukan. Berbeda dengan partikel に yang menandai tempat keberadaan (ada di mana), で menandai lokasi berlangsungnya suatu tindakan.",
      "examples": [
        {
          "japanese": "うちで テレビを みます。",
          "romaji": "Uchi de terebi o mimasu.",
          "indonesian": "Saya menonton TV di rumah."
        },
        {
          "japanese": "としょかんで ほんを よみます。",
          "romaji": "Toshokan de hon o yomimasu.",
          "indonesian": "Saya membaca buku di perpustakaan."
        }
      ]
    },
    {
      "id": "ch06_g03",
      "chapterId": 6,
      "order": 3,
      "title": "Pola もう V ました / まだ V ていません",
      "explanation": "Pola ini digunakan untuk menanyakan dan menjawab apakah suatu tindakan sudah dilakukan atau belum. ??? (mou) berarti 'sudah', digunakan dalam pertanyaan ?????ま??? dan jawaban positif は???????ま??. Untuk jawaban negatif 'belum', digunakan まだ??て?ま???.",
      "examples": [
        {
          "japanese": "もう ばんごはんを たべましたか。 — はい、もう たべました。",
          "romaji": "Mou bangohan o tabemashita ka. â€” Hai, mou tabemashita.",
          "indonesian": "Sudahkah makan malam? â€” Ya, sudah makan."
        },
        {
          "japanese": "もう しゅくだいを しましたか。 — いいえ、まだ していません。",
          "romaji": "Mou shukudai o shimashita ka. â€” Iie, mada shite imasen.",
          "indonesian": "Sudahkah mengerjakan PR? â€” Belum, belum dikerjakan."
        }
      ]
    }
  ],
  "patterns": [
    {
      "id": "ch06_p01",
      "chapterId": 6,
      "order": 1,
      "pattern": "N を V",
      "explanation": "Partikel を (wo/o) menandai objek langsung dari suatu tindakan. Digunakan sebelum verba transitif untuk menunjukkan apa yang menjadi objek dari tindakan tersebut.",
      "examples": [
        {
          "japanese": "私は まいあさ パンを たべます。",
          "romaji": "Watashi wa maiasa pan o tabemasu.",
          "indonesian": "Saya makan roti setiap pagi."
        },
        {
          "japanese": "コーヒーを のみます。",
          "romaji": "Koohii o nomimasu.",
          "indonesian": "Saya minum kopi."
        }
      ]
    },
    {
      "id": "ch06_p02",
      "chapterId": 6,
      "order": 2,
      "pattern": "N で V",
      "explanation": "Partikel で (de) menandai tempat di mana suatu kegiatan dilakukan. Berbeda dengan に yang menandai keberadaan, で menandai lokasi aktivitas.",
      "examples": [
        {
          "japanese": "うちで テレビを みます。",
          "romaji": "Uchi de terebi o mimasu.",
          "indonesian": "Saya menonton TV di rumah."
        },
        {
          "japanese": "としょかんで ほんを よみます。",
          "romaji": "Toshokan de hon o yomimasu.",
          "indonesian": "Saya membaca buku di perpustakaan."
        }
      ]
    },
    {
      "id": "ch06_p03",
      "chapterId": 6,
      "order": 3,
      "pattern": "もう V ました",
      "explanation": "Pola pertanyaan untuk menanyakan apakah suatu tindakan sudah dilakukan. ??? (mou) berarti 'sudah'. Jawaban positif: は????? V ま??. Jawaban negatif: ????まだで?.",
      "examples": [
        {
          "japanese": "もう ばんごはんを たべましたか。",
          "romaji": "Mou bangohan o tabemashita ka.",
          "indonesian": "Sudahkah makan malam?"
        },
        {
          "japanese": "もう しゅくだいを しましたか。",
          "romaji": "Mou shukudai o shimashita ka.",
          "indonesian": "Sudahkah mengerjakan PR?"
        }
      ]
    },
    {
      "id": "ch06_p04",
      "chapterId": 6,
      "order": 4,
      "pattern": "まだ V ていません",
      "explanation": "Pola untuk menyatakan bahwa suatu tindakan belum dilakukan. まだ (mada) berarti 'belum/masih'. Digunakan sebagai jawaban negatif untuk pertanyaan ????ま???.",
      "examples": [
        {
          "japanese": "まだ たべていません。",
          "romaji": "Mada tabete imasen.",
          "indonesian": "Belum makan."
        },
        {
          "japanese": "まだ しゅくだいを していません。",
          "romaji": "Mada shukudai o shite imasen.",
          "indonesian": "Belum mengerjakan PR."
        }
      ]
    }
  ],
