  "conversations": [
    {
      "id": "ch06_conv01",
      "chapterId": 6,
      "order": 1,
      "title": "Percakapan 1 - Kegiatan Sehari-hari",
      "turns": [
        {
          "speaker": "やまだ",
          "japanese": "ミラーさんは まいあさ なにを たべますか。",
          "romaji": "Miraa-san wa maiasa nani o tabemasu ka.",
          "indonesian": "Tuan Miller, setiap pagi makan apa?",
          "hiragana": "ミラーさんは まいあさ なにを たべますか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "パンと たまごを たべます。コーヒーも のみます。やまださんは？",
          "romaji": "Pan to tamago o tabemasu. Koohii mo nomimasu. Yamada-san wa?",
          "indonesian": "Saya makan roti dan telur. Minum kopi juga. Yamada?",
          "hiragana": "パンと たまごを たべます。コーヒーも のみます。やまださんは？"
        },
        {
          "speaker": "やまだ",
          "japanese": "私は ごはんと みそしるを たべます。",
          "romaji": "Watashi wa gohan to misoshiru o tabemasu.",
          "indonesian": "Saya makan nasi dan sup miso.",
          "hiragana": "わたしは ごはんと みそしるを たべます。"
        }
      ]
    },
    {
      "id": "ch06_conv02",
      "chapterId": 6,
      "order": 2,
      "title": "Percakapan 2 - Sudah Makan?",
      "turns": [
        {
          "speaker": "カリナ",
          "japanese": "もう ひるごはんを たべましたか。",
          "romaji": "Mou hirugohan o tabemashita ka.",
          "indonesian": "Sudah makan siang?",
          "hiragana": "もう ひるごはんを たべましたか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "いいえ、まだです。カリナさんは？",
          "romaji": "Iie, mada desu. Karina-san wa?",
          "indonesian": "Belum. Karina?",
          "hiragana": "いいえ、まだです。カリナさんは？"
        },
        {
          "speaker": "カリナ",
          "japanese": "私も まだです。いっしょに しょくどうへ いきませんか。",
          "romaji": "Watashi mo mada desu. Issho ni shokudou e ikimasen ka.",
          "indonesian": "Saya juga belum. Mau pergi ke kantin bersama?",
          "hiragana": "わたしも まだです。いっしょに しょくどうへ いきませんか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "いいですね。いきましょう。",
          "romaji": "Ii desu ne. Ikimashou.",
          "indonesian": "Bagus. Ayo pergi.",
          "hiragana": "いいですね。いきましょう。"
        }
      ]
    },
