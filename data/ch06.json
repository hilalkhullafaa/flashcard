  "grammar": [
    {
      "id": "ch06_g01",
      "chapterId": 6,
      "order": 1,
      "title": "Partikel を (wo) — Penanda Objek Langsung",
      "explanation": "Partikel を (dibaca 'o') digunakan untuk menandai objek langsung dari verba transitif — yaitu benda atau orang yang dikenai tindakan. Partikel ini selalu diletakkan setelah nomina dan sebelum verba.",
      "examples": [
        { "japanese": "わたしは まいあさ パンを たべます。", "romaji": "Watashi wa maiasa pan o tabemasu.", "indonesian": "Saya makan roti setiap pagi." },
        { "japanese": "コーヒーを のみます。", "romaji": "Koohii o nomimasu.", "indonesian": "Saya minum kopi." }
      ]
    },
    {
      "id": "ch06_g02",
      "chapterId": 6,
      "order": 2,
      "title": "Partikel で — Tempat Kegiatan",
      "explanation": "Partikel で menandai tempat di mana suatu kegiatan atau aktivitas dilakukan. Berbeda dengan partikel に yang menandai tempat keberadaan (ada di mana), で menandai lokasi berlangsungnya suatu tindakan.",
      "examples": [
        { "japanese": "うちで テレビを みます。", "romaji": "Uchi de terebi o mimasu.", "indonesian": "Saya menonton TV di rumah." },
        { "japanese": "としょかんで ほんを よみます。", "romaji": "Toshokan de hon o yomimasu.", "indonesian": "Saya membaca buku di perpustakaan." }
      ]
    },
    {
      "id": "ch06_g03",
      "chapterId": 6,
      "order": 3,
      "title": "Pola もう〜ました / まだ〜ていません",
      "explanation": "Pola ini digunakan untuk menanyakan dan menjawab apakah suatu tindakan sudah dilakukan atau belum. もう (mou) berarti 'sudah', digunakan dalam pertanyaan もう〜ましたか dan jawaban positif はい、もう〜ました. Untuk jawaban negatif 'belum', digunakan まだ〜ていません.",
      "examples": [
        { "japanese": "もう ばんごはんを たべましたか。 — はい、もう たべました。", "romaji": "Mou bangohan o tabemashita ka. — Hai, mou tabemashita.", "indonesian": "Sudahkah makan malam? — Ya, sudah makan." },
        { "japanese": "もう しゅくだいを しましたか。 — いいえ、まだ していません。", "romaji": "Mou shukudai o shimashita ka. — Iie, mada shite imasen.", "indonesian": "Sudahkah mengerjakan PR? — Belum, belum dikerjakan." }
      ]
    }
