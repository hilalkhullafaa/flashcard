  "conversations": [
    {
      "id": "ch06_conv01",
      "chapterId": 6,
      "order": 1,
      "title": "Percakapan 1 — Kegiatan Sehari-hari",
      "turns": [
        { "speaker": "やまだ", "japanese": "ミラーさんは まいあさ なにを たべますか。", "romaji": "Miraa-san wa maiasa nani o tabemasu ka.", "indonesian": "Tuan Miller, setiap pagi makan apa?" },
        { "speaker": "ミラー", "japanese": "パンと たまごを たべます。コーヒーも のみます。やまださんは？", "romaji": "Pan to tamago o tabemasu. Koohii mo nomimasu. Yamada-san wa?", "indonesian": "Saya makan roti dan telur. Minum kopi juga. Yamada?" },
        { "speaker": "やまだ", "japanese": "わたしは ごはんと みそしるを たべます。", "romaji": "Watashi wa gohan to misoshiru o tabemasu.", "indonesian": "Saya makan nasi dan sup miso." }
      ]
    },
    {
      "id": "ch06_conv02",
      "chapterId": 6,
      "order": 2,
      "title": "Percakapan 2 — Sudah Makan?",
      "turns": [
        { "speaker": "カリナ", "japanese": "もう ひるごはんを たべましたか。", "romaji": "Mou hirugohan o tabemashita ka.", "indonesian": "Sudah makan siang?" },
        { "speaker": "ミラー", "japanese": "いいえ、まだです。カリナさんは？", "romaji": "Iie, mada desu. Karina-san wa?", "indonesian": "Belum. Karina?" },
