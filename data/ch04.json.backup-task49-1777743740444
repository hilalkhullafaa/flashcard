  "conversations": [
    {
      "id": "ch04_conv01",
      "chapterId": 4,
      "order": 1,
      "title": "Percakapan 1 — Jam Kerja",
      "turns": [
        {
          "speaker": "ミラー",
          "japanese": "銀行は 何時から 何時までですか。",
          "romaji": "Ginkou wa nanji kara nanji made desu ka.",
          "indonesian": "Bank buka dari jam berapa sampai jam berapa?",
          "hiragana": "ぎんこうは なんじから なんじまでですか。"
        },
        {
          "speaker": "やまだ",
          "japanese": "午前 9じから 午後 3じまでです。",
          "romaji": "Gozen kuji kara gogo sanji made desu.",
          "indonesian": "Dari jam 9 pagi sampai jam 3 sore.",
          "hiragana": "ごぜん 9じから ごご 3じまでです。"
        },
        {
          "speaker": "ミラー",
          "japanese": "土曜日も ひらいていますか。",
          "romaji": "Doyoubi mo hiraite imasu ka.",
          "indonesian": "Apakah hari Sabtu juga buka?",
          "hiragana": "どようびも ひらいていますか。"
        },
        {
          "speaker": "やまだ",
          "japanese": "はい。でも 日曜日は 休みです。",
          "romaji": "Hai. Demo nichiyoubi wa yasumi desu.",
          "indonesian": "Ya. Tapi hari Minggu tutup.",
          "hiragana": "はい。でも にちようびは やすみです。"
        }
      ]
    },
    {
      "id": "ch04_conv02",
      "chapterId": 4,
      "order": 2,
      "title": "Percakapan 2 — Jadwal Harian",
      "turns": [
        {
          "speaker": "カリナ",
          "japanese": "ミラーさんは 毎日 何時に 起来ますか。",
          "romaji": "Miraa-san wa mainichi nanji ni okimasu ka.",
          "indonesian": "Tuan Miller, setiap hari bangun jam berapa?",
          "hiragana": "ミラーさんは まいにち なんじに おきますか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "6じに 起来ます。カリナさんは？",
          "romaji": "Rokuji ni okimasu. Karina-san wa?",
          "indonesian": "Bangun jam 6. Karina?",
          "hiragana": "6じに おきます。カリナさんは？"
        },
        {
          "speaker": "カリナ",
          "japanese": "私は 7じに 起来ます。仕事は 9じから 5じまでです。",
          "romaji": "Watashi wa shichiji ni okimasu. Shigoto wa kuji kara goji made desu.",
          "indonesian": "Saya bangun jam 7. Kerja dari jam 9 sampai jam 5.",
          "hiragana": "わたしは 7じに おきます。しごとは 9じから 5じまでです。"
        }
      ]
    },
    {
      "id": "ch04_conv03",
      "chapterId": 4,
      "order": 3,
      "title": "Percakapan 3 — Waktu Istirahat",
      "turns": [
        {
          "speaker": "サントス",
          "japanese": "ひる休みは 何時から 何時までですか。",
          "romaji": "Hiruyasumi wa nanji kara nanji made desu ka.",
          "indonesian": "Istirahat siang dari jam berapa sampai jam berapa?",
          "hiragana": "ひるやすみは なんじから なんじまでですか。"
        },
        {
          "speaker": "やまだ",
          "japanese": "12じから 1じまでです。",
          "romaji": "Juuniji kara ichiji made desu.",
          "indonesian": "Dari jam 12 sampai jam 1.",
          "hiragana": "12じから 1じまでです。"
        },
        {
          "speaker": "サントス",
          "japanese": "仕事は 何時に 終わりますか。",
          "romaji": "Shigoto wa nanji ni owarimasu ka.",
          "indonesian": "Jam berapa pekerjaan selesai?",
          "hiragana": "しごとは なんじに おわりますか。"
        },
        {
          "speaker": "やまだ",
          "japanese": "午後 5じに 終わります。",
          "romaji": "Gogo goji ni owarimasu.",
          "indonesian": "Selesai jam 5 sore.",
          "hiragana": "ごご 5じに おわります。"
        }
      ]
    },
    {
      "id": "ch04_conv04",
      "chapterId": 4,
      "order": 4,
      "title": "Percakapan 4 — Hari Libur",
      "turns": [
        {
          "speaker": "ミラー",
          "japanese": "やまださんは 何曜日に 休見ますか。",
          "romaji": "Yamada-san wa nanyoubi ni yasumimasu ka.",
          "indonesian": "Yamada, hari apa Anda libur?",
          "hiragana": "やまださんは なんようびに やすみますか。"
        },
        {
          "speaker": "やまだ",
          "japanese": "土曜日と 日曜日に 休見ます。",
          "romaji": "Doyoubi to nichiyoubi ni yasumimasu.",
          "indonesian": "Saya libur hari Sabtu dan Minggu.",
          "hiragana": "どようびと にちようびに やすみます。"
        },
        {
          "speaker": "ミラー",
          "japanese": "いいですね。",
          "romaji": "Ii desu ne.",
          "indonesian": "Bagus ya.",
          "hiragana": "いいですね。"
        }
      ]
    },
    {
      "id": "ch04_conv05",
      "chapterId": 4,
      "order": 5,
      "title": "Percakapan 5 — Waktu Ujian",
      "turns": [
        {
          "speaker": "カリナ",
          "japanese": "試験は 何時からですか。",
          "romaji": "Shiken wa nanji kara desu ka.",
          "indonesian": "Ujian mulai jam berapa?",
          "hiragana": "しけんは なんじからですか。"
        },
        {
          "speaker": "サントス",
          "japanese": "午前 9じからです。",
          "romaji": "Gozen kuji kara desu.",
