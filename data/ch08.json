  "conversations": [
    {
      "id": "ch08_conv01",
      "chapterId": 8,
      "order": 1,
      "title": "Percakapan 1 — Di Toko Buah",
      "turns": [
        { "speaker": "てんいん", "japanese": "いらっしゃいませ。", "romaji": "Irasshaimase.", "indonesian": "Selamat datang." },
        { "speaker": "ミラー", "japanese": "りんごを みっつ ください。", "romaji": "Ringo o mittsu kudasai.", "indonesian": "Tolong tiga buah apel." },
        { "speaker": "てんいん", "japanese": "はい。ほかに なにか？", "romaji": "Hai. Hoka ni nanika?", "indonesian": "Baik. Ada yang lain?" },
        { "speaker": "ミラー", "japanese": "ぎゅうにゅうを 1ほん おねがいします。ぜんぶで いくらですか。", "romaji": "Gyuunyuu o ippon onegai shimasu. Zenbu de ikura desu ka.", "indonesian": "Satu botol susu juga. Semuanya berapa?" },
        { "speaker": "てんいん", "japanese": "580えんです。", "romaji": "Gohyaku hachijuu en desu.", "indonesian": "580 yen." }
      ]
    },
    {
      "id": "ch08_conv02",
      "chapterId": 8,
      "order": 2,
      "title": "Percakapan 2 — Menanyakan Jumlah",
      "turns": [
        { "speaker": "カリナ", "japanese": "ねこが なんびき いますか。", "romaji": "Neko ga nanbiki imasu ka.", "indonesian": "Ada berapa ekor kucing?" },
        { "speaker": "ミラー", "japanese": "3びき います。", "romaji": "Sanbiki imasu.", "indonesian": "Ada 3 ekor." },
        { "speaker": "カリナ", "japanese": "かわいいですね。いぬは いますか。", "romaji": "Kawaii desu ne. Inu wa imasu ka.", "indonesian": "Lucu ya. Ada anjing?" },
        { "speaker": "ミラー", "japanese": "いいえ、いません。", "romaji": "Iie, imasen.", "indonesian": "Tidak ada." }
      ]
    }
  ],
  "grammar": [
    {
      "id": "ch08_g01",
      "chapterId": 8,
      "order": 1,
      "title": "Kata Penggolong (助数詞) dalam Bahasa Jepang",
      "explanation": "Bahasa Jepang menggunakan kata penggolong (josushi) yang berbeda-beda tergantung jenis benda yang dihitung. Pengucapan angka pun sering berubah saat digabung dengan penggolong tertentu karena proses asimilasi bunyi. Misalnya, 1本 dibaca 'ippon' bukan 'ichipon', dan 3本 dibaca 'sanbon'. Memilih penggolong yang tepat adalah bagian penting dari tata bahasa Jepang.",
      "examples": [
        { "japanese": "ぎゅうにゅうを 1ほん ください。", "romaji": "Gyuunyuu o ippon kudasai.", "indonesian": "Tolong satu botol susu." },
        { "japanese": "きってを 5まい ください。", "romaji": "Kitte o gomai kudasai.", "indonesian": "Tolong 5 lembar perangko." }
      ]
    },
    {
      "id": "ch08_g02",
      "chapterId": 8,
      "order": 2,
      "title": "Sistem Bilangan Asli Jepang (和語数詞)",
      "explanation": "Selain sistem bilangan Sino-Jepang (ichi, ni, san...), bahasa Jepang memiliki sistem bilangan asli (wago) untuk menghitung benda secara umum hingga sepuluh: hitotsu, futatsu, mittsu, yottsu, itsutsu, muttsu, nanatsu, yattsu, kokonotsu, too. Sistem ini digunakan tanpa kata penggolong khusus dan sering dipakai untuk menghitung buah, makanan, atau benda umum.",
      "examples": [
        { "japanese": "りんごを みっつ ください。", "romaji": "Ringo o mittsu kudasai.", "indonesian": "Tolong tiga buah apel." },
        { "japanese": "たまごが ふたつ あります。", "romaji": "Tamago ga futatsu arimasu.", "indonesian": "Ada dua butir telur." }
      ]
    },
    {
      "id": "ch08_g03",
