  "grammar": [
    {
      "id": "ch10_g01",
      "chapterId": 10,
      "order": 1,
      "title": "Partikel が ” Penanda Objek Kemampuan",
      "explanation": "Dalam bahasa Jepang, verba kemampuan seperti できます (bisa) dan verba pemahaman seperti わかります (mengerti) menggunakan partikel が, bukan を, untuk menandai objeknya. Ini berbeda dari verba aksi biasa yang menggunakan を. Pola ini juga berlaku untuk adjektiva kemampuan seperti じょうず dan へた.",
      "examples": [
        {
          "japanese": "日本語が わかります。",
          "romaji": "Nihongo ga wakarimasu.",
          "indonesian": "Saya mengerti bahasa Jepang."
        },
        {
          "japanese": "運転が できます。",
          "romaji": "Unten ga dekimasu.",
          "indonesian": "Saya bisa mengemudi."
        }
      ]
    },
    {
      "id": "ch10_g02",
      "chapterId": 10,
      "order": 2,
      "title": "Bentuk Potensial (Dapat/Bisa)",
      "explanation": "Bentuk potensial menyatakan kemampuan atau kemungkinan melakukan sesuatu. Untuk verba する (suru), bentuk potensialnya adalah できます (dekimasu). できます juga dapat digunakan secara mandiri dengan nomina + が untuk menyatakan kemampuan umum. Untuk menyatakan 'tidak bisa', gunakan できません.",
      "examples": [
        {
          "japanese": "日本語が すこし はなせます。",
          "romaji": "Nihongo ga sukoshi hanasemasu.",
          "indonesian": "Saya bisa sedikit berbicara bahasa Jepang."
        },
        {
          "japanese": "ピアノが できます。",
          "romaji": "Piano ga dekimasu.",
          "indonesian": "Saya bisa (bermain) piano."
        }
      ]
    },
    {
      "id": "ch10_g03",
      "chapterId": 10,
      "order": 3,
      "title": "Adjektiva-na: じょうず・へた・とくい",
      "explanation": "Ketiga kata ini adalah adjektiva-na yang menyatakan tingkat kemampuan. じょうず (jouzu) berarti pandai/mahir secara umum, へた (heta) berarti tidak pandai/kurang mahir, dan とくい (tokui) berarti pandai dalam bidang tertentu yang disukai. Saat memodifikasi nomina, tambahkan な sebelum nomina. Saat menjadi predikat, gunakan です.",
      "examples": [
        {
          "japanese": "ミラーさんは 日本語が じょうずです。",
          "romaji": "Miraa-san wa nihongo ga jouzu desu.",
          "indonesian": "Tuan Miller pandai berbahasa Jepang."
        },
        {
          "japanese": "私は 料理が とくいです。",
          "romaji": "Watashi wa ryouri ga tokui desu.",
          "indonesian": "Saya ahli dalam memasak."
        }
      ]
    }
  ],
  "patterns": [
    {
      "id": "ch10_p01",
      "chapterId": 10,
      "order": 1,
      "pattern": "N が できます",
      "explanation": "Pola untuk menyatakan kemampuan melakukan sesuatu. Partikel が (ga) menandai hal yang bisa dilakukan. できます (dekimasu) berarti 'bisa/mampu'. Dapat dimodifikasi dengan すこし (sedikit) atau ぜんぜんできません (sama sekali tidak bisa).",
      "examples": [
        {
          "japanese": "日本語が すこし はなせます。",
          "romaji": "Nihongo ga sukoshi hanasemasu.",
          "indonesian": "Saya bisa sedikit berbicara bahasa Jepang."
        },
        {
          "japanese": "運転が できます。",
          "romaji": "Unten ga dekimasu.",
          "indonesian": "Saya bisa mengemudi."
        }
      ]
    },
    {
      "id": "ch10_p02",
      "chapterId": 10,
      "order": 2,
      "pattern": "N が じょうずです",
      "explanation": "Pola untuk menyatakan bahwa seseorang pandai atau mahir dalam sesuatu. じょうず (jouzu) adalah adjektiva-na yang berarti 'pandai/mahir'. Kebalikannya adalah へた (heta) yang berarti 'tidak pandai'.",
      "examples": [
        {
          "japanese": "ミラーさんは 日本語が じょうずです。",
          "romaji": "Miraa-san wa nihongo ga jouzu desu.",
          "indonesian": "Tuan Miller pandai berbahasa Jepang."
        },
        {
          "japanese": "私は 料理が じょうずです。",
          "romaji": "Watashi wa ryouri ga jouzu desu.",
          "indonesian": "Saya pandai memasak."
        }
      ]
    },
    {
      "id": "ch10_p03",
      "chapterId": 10,
      "order": 3,
      "pattern": "N が わかります",
      "explanation": "Pola untuk menyatakan bahwa seseorang mengerti atau memahami sesuatu. わかります (wakarimasu) berarti 'mengerti/memahami'. Partikel が menandai hal yang dimengerti.",
      "examples": [
        {
          "japanese": "漢字が すこし わかります。",
          "romaji": "Kanji ga sukoshi wakarimasu.",
          "indonesian": "Saya sedikit mengerti kanji."
        },
        {
          "japanese": "英語が わかりますか。",
          "romaji": "Eigo ga wakarimasu ka.",
          "indonesian": "Apakah Anda mengerti bahasa Inggris?"
        }
      ]
    }
  ],
