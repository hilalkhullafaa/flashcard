  "conversations": [
    {
      "id": "ch10_conv01",
      "chapterId": 10,
      "order": 1,
      "title": "Percakapan 1 — Kemampuan Bahasa",
      "turns": [
        { "speaker": "やまだ", "japanese": "ミラーさんは にほんごが じょうずですね。", "romaji": "Miraa-san wa nihongo ga jouzu desu ne.", "indonesian": "Bahasa Jepang Tuan Miller bagus ya." },
        { "speaker": "ミラー", "japanese": "いいえ、まだまだです。すこし はなせますが、かんじは あまり わかりません。", "romaji": "Iie, madamada desu. Sukoshi hanasemasu ga, kanji wa amari wakarimasen.", "indonesian": "Tidak, masih jauh. Bisa sedikit berbicara, tapi kanji kurang mengerti." },
        { "speaker": "やまだ", "japanese": "ひらがなと カタカナは よめますか。", "romaji": "Hiragana to katakana wa yomemasu ka.", "indonesian": "Hiragana dan katakana bisa dibaca?" },
        { "speaker": "ミラー", "japanese": "はい、よめます。でも かくのは むずかしいです。", "romaji": "Hai, yomemasu. Demo kaku no wa muzukashii desu.", "indonesian": "Ya, bisa. Tapi menulisnya sulit." }
      ]
    },
    {
      "id": "ch10_conv02",
      "chapterId": 10,
      "order": 2,
      "title": "Percakapan 2 — Hobi dan Kemampuan",
      "turns": [
        { "speaker": "カリナ", "japanese": "ミラーさんは ピアノが できますか。", "romaji": "Miraa-san wa piano ga dekimasu ka.", "indonesian": "Tuan Miller bisa main piano?" },
        { "speaker": "ミラー", "japanese": "はい、すこし できます。カリナさんは？", "romaji": "Hai, sukoshi dekimasu. Karina-san wa?", "indonesian": "Ya, bisa sedikit. Karina?" },
        { "speaker": "カリナ", "japanese": "わたしは ギターが すこし ひけます。でも うたは にがてです。", "romaji": "Watashi wa gitaa ga sukoshi hikemasu. Demo uta wa nigate desu.", "indonesian": "Saya bisa sedikit main gitar. Tapi menyanyi kurang bisa." }
      ]
    }
  ],
  "grammar": [
    {
      "id": "ch10_g01",
      "chapterId": 10,
      "order": 1,
      "title": "Partikel が — Penanda Objek Kemampuan",
      "explanation": "Dalam bahasa Jepang, verba kemampuan seperti できます (bisa) dan verba pemahaman seperti わかります (mengerti) menggunakan partikel が, bukan を, untuk menandai objeknya. Ini berbeda dari verba aksi biasa yang menggunakan を. Pola ini juga berlaku untuk adjektiva kemampuan seperti じょうず dan へた.",
      "examples": [
        { "japanese": "にほんごが わかります。", "romaji": "Nihongo ga wakarimasu.", "indonesian": "Saya mengerti bahasa Jepang." },
        { "japanese": "うんてんが できます。", "romaji": "Unten ga dekimasu.", "indonesian": "Saya bisa mengemudi." }
      ]
    },
    {
      "id": "ch10_g02",
      "chapterId": 10,
      "order": 2,
      "title": "Bentuk Potensial (Dapat/Bisa)",
      "explanation": "Bentuk potensial menyatakan kemampuan atau kemungkinan melakukan sesuatu. Untuk verba する (suru), bentuk potensialnya adalah できます (dekimasu). できます juga dapat digunakan secara mandiri dengan nomina + が untuk menyatakan kemampuan umum. Untuk menyatakan 'tidak bisa', gunakan できません.",
      "examples": [
        { "japanese": "にほんごが すこし はなせます。", "romaji": "Nihongo ga sukoshi hanasemasu.", "indonesian": "Saya bisa sedikit berbicara bahasa Jepang." },
        { "japanese": "ピアノが できます。", "romaji": "Piano ga dekimasu.", "indonesian": "Saya bisa (bermain) piano." }
      ]
    },
    {
      "id": "ch10_g03",
      "chapterId": 10,
      "order": 3,
      "title": "Adjektiva-na: じょうず・へた・とくい",
      "explanation": "Ketiga kata ini adalah adjektiva-na yang menyatakan tingkat kemampuan. じょうず (jouzu) berarti pandai/mahir secara umum, へた (heta) berarti tidak pandai/kurang mahir, dan とくい (tokui) berarti pandai dalam bidang tertentu yang disukai. Saat memodifikasi nomina, tambahkan な sebelum nomina. Saat menjadi predikat, gunakan です.",
      "examples": [
        { "japanese": "ミラーさんは にほんごが じょうずです。", "romaji": "Miraa-san wa nihongo ga jouzu desu.", "indonesian": "Tuan Miller pandai berbahasa Jepang." },
        { "japanese": "わたしは りょうりが とくいです。", "romaji": "Watashi wa ryouri ga tokui desu.", "indonesian": "Saya ahli dalam memasak." }
      ]
    }
  ],
  "patterns": [
    {
      "id": "ch10_p01",
      "chapterId": 10,
      "order": 1,
      "pattern": "N が できます",
      "explanation": "Pola untuk menyatakan kemampuan melakukan sesuatu. Partikel が (ga) menandai hal yang bisa dilakukan. できます (dekimasu) berarti 'bisa/mampu'. Dapat dimodifikasi dengan すこし (sedikit) atau ぜんぜん～できません (sama sekali tidak bisa).",
      "examples": [
        { "japanese": "にほんごが すこし はなせます。", "romaji": "Nihongo ga sukoshi hanasemasu.", "indonesian": "Saya bisa sedikit berbicara bahasa Jepang." },
        { "japanese": "うんてんが できます。", "romaji": "Unten ga dekimasu.", "indonesian": "Saya bisa mengemudi." }
      ]
    },
    {
      "id": "ch10_p02",
      "chapterId": 10,
      "order": 2,
      "pattern": "N が じょうずです",
      "explanation": "Pola untuk menyatakan bahwa seseorang pandai atau mahir dalam sesuatu. じょうず (jouzu) adalah adjektiva-na yang berarti 'pandai/mahir'. Kebalikannya adalah へた (heta) yang berarti 'tidak pandai'.",
      "examples": [
        { "japanese": "ミラーさんは にほんごが じょうずです。", "romaji": "Miraa-san wa nihongo ga jouzu desu.", "indonesian": "Tuan Miller pandai berbahasa Jepang." },
        { "japanese": "わたしは りょうりが じょうずです。", "romaji": "Watashi wa ryouri ga jouzu desu.", "indonesian": "Saya pandai memasak." }
      ]
    },
    {
      "id": "ch10_p03",
      "chapterId": 10,
      "order": 3,
      "pattern": "N が わかります",
      "explanation": "Pola untuk menyatakan bahwa seseorang mengerti atau memahami sesuatu. わかります (wakarimasu) berarti 'mengerti/memahami'. Partikel が menandai hal yang dimengerti.",
      "examples": [
        { "japanese": "かんじが すこし わかります。", "romaji": "Kanji ga sukoshi wakarimasu.", "indonesian": "Saya sedikit mengerti kanji." },
        { "japanese": "えいごが わかりますか。", "romaji": "Eigo ga wakarimasu ka.", "indonesian": "Apakah Anda mengerti bahasa Inggris?" }
      ]
    }
  ],
  "quiz": [
    {
      "id": "ch10_q01",
      "chapterId": 10,
      "order": 1,
      "question": "Apa arti kata 'できます' (dekimasu)?",
