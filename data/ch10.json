  "conversations": [
    {
      "id": "ch10_conv01",
      "chapterId": 10,
      "order": 1,
      "title": "Percakapan 1 - Kemampuan Bahasa",
      "turns": [
        {
          "speaker": "やまだ",
          "japanese": "ミラーさんは 日本語が じょうずですね。",
          "romaji": "Miraa-san wa nihongo ga jouzu desu ne.",
          "indonesian": "Bahasa Jepang Tuan Miller bagus ya.",
          "hiragana": "ミラーさんは にほんごが じょうずですね。"
        },
        {
          "speaker": "ミラー",
          "japanese": "いいえ、まだまだです。すこし はなせますが、かんじは あまり わかりません。",
          "romaji": "Iie, madamada desu. Sukoshi hanasemasu ga, kanji wa amari wakarimasen.",
          "indonesian": "Tidak, masih jauh. Bisa sedikit berbicara, tapi kanji kurang mengerti.",
          "hiragana": "いいえ、まだまだです。すこし はなせますが、かんじは あまり わかりません。"
        },
        {
          "speaker": "やまだ",
          "japanese": "ひらがなと カタカナは よめますか。",
          "romaji": "Hiragana to katakana wa yomemasu ka.",
          "indonesian": "Hiragana dan katakana bisa dibaca?",
          "hiragana": "ひらがなと カタカナは よめますか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "はい、よめます。でも かくのは むずかしいです。",
          "romaji": "Hai, yomemasu. Demo kaku no wa muzukashii desu.",
          "indonesian": "Ya, bisa. Tapi menulisnya sulit.",
          "hiragana": "はい、よめます。でも かくのは むずかしいです。"
        }
      ]
    },
    {
      "id": "ch10_conv02",
      "chapterId": 10,
      "order": 2,
      "title": "Percakapan 2 - Hobi dan Kemampuan",
      "turns": [
        {
          "speaker": "カリナ",
          "japanese": "ミラーさんは ピアノが できますか。",
          "romaji": "Miraa-san wa piano ga dekimasu ka.",
          "indonesian": "Tuan Miller bisa main piano?",
          "hiragana": "ミラーさんは ピアノが できますか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "はい、すこし できます。カリナさんは？",
          "romaji": "Hai, sukoshi dekimasu. Karina-san wa?",
          "indonesian": "Ya, bisa sedikit. Karina?",
          "hiragana": "はい、すこし できます。カリナさんは？"
        },
        {
          "speaker": "カリナ",
          "japanese": "私は ギターが すこし ひけます。でも うたは にがてです。",
          "romaji": "Watashi wa gitaa ga sukoshi hikemasu. Demo uta wa nigate desu.",
          "indonesian": "Saya bisa sedikit main gitar. Tapi menyanyi kurang bisa.",
          "hiragana": "わたしは ギターが すこし ひけます。でも うたは にがてです。"
        }
      ]
    },
    {
      "id": "ch10_conv03",
      "chapterId": 10,
      "order": 3,
      "title": "Percakapan 3 — Ada Kucing",
      "turns": [
        {
          "speaker": "ミラー",
          "japanese": "へやに なにが いますか。",
          "romaji": "Heya ni nani ga imasu ka.",
          "indonesian": "Ada apa di kamar?",
          "hiragana": "へやに なにが いますか。"
        },
        {
          "speaker": "カリナ",
          "japanese": "ねこが います。",
          "romaji": "Neko ga imasu.",
          "indonesian": "Ada kucing.",
          "hiragana": "ねこが います。"
        }
      ]
    },
    {
      "id": "ch10_conv04",
      "chapterId": 10,
      "order": 4,
      "title": "Percakapan 4 — Ada Meja",
      "turns": [
        {
          "speaker": "やまだ",
          "japanese": "へやに なにが ありますか。",
          "romaji": "Heya ni nani ga arimasu ka.",
          "indonesian": "Ada apa di kamar?",
          "hiragana": "へやに なにが ありますか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "つくえと いすが あります。",
          "romaji": "Tsukue to isu ga arimasu.",
          "indonesian": "Ada meja dan kursi.",
          "hiragana": "つくえと いすが あります。"
        }
      ]
    },
    {
      "id": "ch10_conv05",
      "chapterId": 10,
      "order": 5,
      "title": "Percakapan 5 — Di Mana Telepon",
      "turns": [
        {
          "speaker": "カリナ",
          "japanese": "でんわは どこに ありますか。",
          "romaji": "Denwa wa doko ni arimasu ka.",
          "indonesian": "Telepon ada di mana?",
          "hiragana": "でんわは どこに ありますか。"
        },
        {
          "speaker": "やまだ",
          "japanese": "つくえの うえに あります。",
          "romaji": "Tsukue no ue ni arimasu.",
          "indonesian": "Ada di atas meja.",
          "hiragana": "つくえの うえに あります。"
        }
      ]
    },
    {
      "id": "ch10_conv06",
      "chapterId": 10,
      "order": 6,
      "title": "Percakapan 6 — Di Mana Anjing",
      "turns": [
        {
          "speaker": "ミラー",
          "japanese": "いぬは どこに いますか。",
          "romaji": "Inu wa doko ni imasu ka.",
          "indonesian": "Anjing ada di mana?",
          "hiragana": "いぬは どこに いますか。"
        },
        {
          "speaker": "カリナ",
          "japanese": "にわに います。",
          "romaji": "Niwa ni imasu.",
          "indonesian": "Ada di taman.",
          "hiragana": "にわに います。"
        }
      ]
    },
    {
      "id": "ch10_conv07",
      "chapterId": 10,
      "order": 7,
      "title": "Percakapan 7 — Ada Berapa Orang",
      "turns": [
        {
          "speaker": "やまだ",
          "japanese": "かぞくは なんにんですか。",
          "romaji": "Kazoku wa nannin desu ka.",
          "indonesian": "Keluarga ada berapa orang?",
          "hiragana": "かぞくは なんにんですか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "4にんです。",
          "romaji": "Yonin desu.",
          "indonesian": "4 orang.",
          "hiragana": "4にんです。"
        }
      ]
    },
    {
      "id": "ch10_conv08",
      "chapterId": 10,
      "order": 8,
      "title": "Percakapan 8 — Ada Toko",
      "turns": [
        {
          "speaker": "カリナ",
          "japanese": "この ちかくに スーパーが ありますか。",
          "romaji": "Kono chikaku ni suupaa ga arimasu ka.",
          "indonesian": "Apakah ada supermarket di dekat sini?",
          "hiragana": "この ちかくに スーパーが ありますか。"
        },
        {
          "speaker": "やまだ",
          "japanese": "はい、あります。えきの まえに あります。",
          "romaji": "Hai, arimasu. Eki no mae ni arimasu.",
          "indonesian": "Ya, ada. Ada di depan stasiun.",
          "hiragana": "はい、あります。えきの まえに あります。"
        }
      ]
