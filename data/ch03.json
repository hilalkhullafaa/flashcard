  "conversations": [
    {
      "id": "ch03_conv01",
      "chapterId": 3,
      "order": 1,
      "title": "Percakapan 1 — Menanyakan Lokasi",
      "turns": [
        { "speaker": "ミラー", "japanese": "すみません、ゆうびんきょくは どこですか。", "romaji": "Sumimasen, yuubinkyoku wa doko desu ka.", "indonesian": "Permisi, di mana kantor pos?" },
        { "speaker": "つうこうにん", "japanese": "あそこです。あの たてものの となりです。", "romaji": "Asoko desu. Ano tatemono no tonari desu.", "indonesian": "Di sana. Di sebelah gedung itu." },
        { "speaker": "ミラー", "japanese": "ありがとうございます。", "romaji": "Arigatou gozaimasu.", "indonesian": "Terima kasih." }
      ]
    },
    {
      "id": "ch03_conv02",
      "chapterId": 3,
      "order": 2,
      "title": "Percakapan 2 — Di Dalam Toko",
      "turns": [
        { "speaker": "てんいん", "japanese": "いらっしゃいませ。", "romaji": "Irasshaimase.", "indonesian": "Selamat datang." },
        { "speaker": "ミラー", "japanese": "すみません、エレベーターは どこですか。", "romaji": "Sumimasen, erebeetaa wa doko desu ka.", "indonesian": "Permisi, di mana lift?" },
        { "speaker": "てんいん", "japanese": "あちらです。", "romaji": "Achira desu.", "indonesian": "Di sana." },
        { "speaker": "ミラー", "japanese": "この かばんは いくらですか。", "romaji": "Kono kaban wa ikura desu ka.", "indonesian": "Berapa harga tas ini?" },
        { "speaker": "てんいん", "japanese": "18,000えんです。", "romaji": "Ichiman hassenhyaku en desu.", "indonesian": "18.000 yen." }
      ]
    }
  ],
  "patterns": [
    {
      "id": "ch03_p01",
      "chapterId": 3,
      "order": 1,
      "pattern": "N は どこですか",
      "explanation": "Menanyakan lokasi suatu tempat atau benda. どこ (doko) berarti 'di mana'.",
      "examples": [
        { "japanese": "トイレは どこですか。", "romaji": "Toire wa doko desu ka.", "indonesian": "Di mana toilet?" },
        { "japanese": "ゆうびんきょくは どこですか。", "romaji": "Yuubinkyoku wa doko desu ka.", "indonesian": "Di mana kantor pos?" }
      ]
    },
    {
      "id": "ch03_p02",
      "chapterId": 3,
      "order": 2,
      "pattern": "N は N の N です",
      "explanation": "Menyatakan posisi relatif suatu tempat atau benda terhadap benda lain menggunakan kata posisi (atas, bawah, depan, dll.).",
      "examples": [
        { "japanese": "エレベーターは あちらです。", "romaji": "Erebeetaa wa achira desu.", "indonesian": "Lift ada di sana." },
        { "japanese": "コンビニは えきの まえです。", "romaji": "Konbini wa eki no mae desu.", "indonesian": "Minimarket ada di depan stasiun." }
      ]
    },
    {
      "id": "ch03_p03",
      "chapterId": 3,
      "order": 3,
      "pattern": "N に N が あります/います",
      "explanation": "Menyatakan keberadaan benda (あります) atau orang/hewan (います) di suatu tempat. Partikel に menandai lokasi, が menandai subjek.",
      "examples": [
        { "japanese": "デパートの となりに ぎんこうが あります。", "romaji": "Depaato no tonari ni ginkou ga arimasu.", "indonesian": "Ada bank di sebelah department store." },
        { "japanese": "としょかんの まえに バスていが あります。", "romaji": "Toshokan no mae ni basutei ga arimasu.", "indonesian": "Ada halte bus di depan perpustakaan." }
      ]
    },
    {
      "id": "ch03_p04",
      "chapterId": 3,
      "order": 4,
      "pattern": "N は いくらですか",
      "explanation": "Menanyakan harga suatu barang. いくら (ikura) berarti 'berapa harganya'.",
