  "conversations": [
    {
      "id": "ch07_conv01",
      "chapterId": 7,
      "order": 1,
      "title": "Percakapan 1 — Kegiatan Hari Minggu",
      "turns": [
        { "speaker": "やまだ", "japanese": "ミラーさんは にちようびに なにを しますか。", "romaji": "Miraa-san wa nichiyoubi ni nani o shimasu ka.", "indonesian": "Tuan Miller, hari Minggu melakukan apa?" },
        { "speaker": "ミラー", "japanese": "ともだちと テニスを します。やまださんは？", "romaji": "Tomodachi to tenisu o shimasu. Yamada-san wa?", "indonesian": "Saya bermain tenis bersama teman. Yamada?" },
        { "speaker": "やまだ", "japanese": "わたしは うちで おんがくを ききます。ときどき えいがも みます。", "romaji": "Watashi wa uchi de ongaku o kikimasu. Tokidoki eiga mo mimasu.", "indonesian": "Saya mendengarkan musik di rumah. Kadang-kadang juga menonton film." }
      ]
    },
    {
      "id": "ch07_conv02",
      "chapterId": 7,
      "order": 2,
      "title": "Percakapan 2 — Memberi Hadiah",
      "turns": [
        { "speaker": "カリナ", "japanese": "ミラーさん、これを どうぞ。", "romaji": "Miraa-san, kore o douzo.", "indonesian": "Tuan Miller, ini untuk Anda." },
        { "speaker": "ミラー", "japanese": "ありがとうございます。なんですか。", "romaji": "Arigatou gozaimasu. Nan desu ka.", "indonesian": "Terima kasih. Apa ini?" },
        { "speaker": "カリナ", "japanese": "インドネシアの おかしです。どうぞ たべて ください。", "romaji": "Indoneshia no okashi desu. Douzo tabete kudasai.", "indonesian": "Ini kue dari Indonesia. Silakan dimakan." },
        { "speaker": "ミラー", "japanese": "わあ、おいしそうですね。ありがとうございます。", "romaji": "Waa, oishisou desu ne. Arigatou gozaimasu.", "indonesian": "Wah, kelihatannya enak. Terima kasih." }
      ]
    }
  ],
  "grammar": [
    {
      "id": "ch07_g01",
      "chapterId": 7,
      "order": 1,
      "title": "Verba あげます・もらいます・くれます — Memberi dan Menerima",
      "explanation": "Bahasa Jepang memiliki tiga verba berbeda untuk konsep memberi dan menerima, tergantung perspektif pembicara. あげます digunakan saat pembicara (atau pihak dalam kelompok pembicara) memberi kepada orang lain. もらいます digunakan saat pembicara menerima sesuatu dari orang lain. くれます digunakan saat orang lain memberi sesuatu kepada pembicara atau kelompoknya.",
      "examples": [
        { "japanese": "ともだちに プレゼントを あげます。", "romaji": "Tomodachi ni purezento o agemasu.", "indonesian": "Saya memberi hadiah kepada teman." },
        { "japanese": "せんせいに ほんを もらいました。", "romaji": "Sensei ni hon o moraimashita.", "indonesian": "Saya mendapat buku dari guru." }
      ]
    },
    {
      "id": "ch07_g02",
      "chapterId": 7,
      "order": 2,
      "title": "Partikel に — Penerima/Pemberi",
      "explanation": "Dalam konteks verba memberi dan menerima, partikel に memiliki dua fungsi. Untuk あげます, に menandai penerima (orang yang diberi). Untuk もらいます, に menandai pemberi (orang yang memberikan sesuatu). Perhatikan bahwa peran に berubah tergantung verba yang digunakan.",
      "examples": [
        { "japanese": "やまださんに てがみを おくります。", "romaji": "Yamada-san ni tegami o okurimasu.", "indonesian": "Saya mengirim surat kepada Yamada." },
        { "japanese": "はははに ケーキを もらいました。", "romaji": "Haha ni keeki o moraimashita.", "indonesian": "Saya mendapat kue dari ibu." }
      ]
    },
    {
      "id": "ch07_g03",
      "chapterId": 7,
      "order": 3,
      "title": "Kata Tanya なに (nani) / なん (nan)",
      "explanation": "なに dan なん keduanya berarti 'apa', namun penggunaannya berbeda. なん digunakan sebelum kata penggolong (counter), sebelum です, dan sebelum の. なに digunakan dalam konteks lain, terutama sebelum partikel を, が, atau di akhir kalimat. Dalam percakapan sehari-hari, なん lebih sering terdengar.",
      "examples": [
        { "japanese": "にちようびに なにを しますか。", "romaji": "Nichiyoubi ni nani o shimasu ka.", "indonesian": "Apa yang Anda lakukan pada hari Minggu?" },
        { "japanese": "しゅみは なんですか。", "romaji": "Shumi wa nan desu ka.", "indonesian": "Apa hobi Anda?" }
      ]
    }
  ],
  "patterns": [
    {
      "id": "ch07_p01",
      "chapterId": 7,
      "order": 1,
      "pattern": "N に N を あげます／もらいます",
      "explanation": "Pola untuk menyatakan memberi atau menerima sesuatu. あげます (agemasu) = memberi kepada orang lain; もらいます (moraimasu) = menerima dari orang lain. Partikel に menandai penerima (untuk あげます) atau pemberi (untuk もらいます).",
      "examples": [
        { "japanese": "ともだちに プレゼントを あげます。", "romaji": "Tomodachi ni purezento o agemasu.", "indonesian": "Saya memberi hadiah kepada teman." },
        { "japanese": "せんせいに ほんを もらいました。", "romaji": "Sensei ni hon o moraimashita.", "indonesian": "Saya mendapat buku dari guru." }
      ]
    },
    {
      "id": "ch07_p02",
      "chapterId": 7,
      "order": 2,
      "pattern": "N と N を します",
      "explanation": "Partikel と (to) digunakan untuk menyatakan melakukan sesuatu bersama seseorang. と menghubungkan orang yang melakukan kegiatan bersama.",
      "examples": [
        { "japanese": "ともだちと テニスを します。", "romaji": "Tomodachi to tenisu o shimasu.", "indonesian": "Saya bermain tenis bersama teman." },
        { "japanese": "かぞくと えいがを みます。", "romaji": "Kazoku to eiga o mimasu.", "indonesian": "Saya menonton film bersama keluarga." }
      ]
    },
    {
      "id": "ch07_p03",
      "chapterId": 7,
      "order": 3,
      "pattern": "しゅみは N です",
      "explanation": "Pola untuk menyatakan hobi. しゅみ (shumi) berarti 'hobi'. Dapat diikuti nomina atau klausa verba dengan こと (koto).",
      "examples": [
        { "japanese": "わたしの しゅみは えいがを みることです。", "romaji": "Watashi no shumi wa eiga o miru koto desu.", "indonesian": "Hobi saya adalah menonton film." },
        { "japanese": "しゅみは おんがくを きくことです。", "romaji": "Shumi wa ongaku o kiku koto desu.", "indonesian": "Hobi saya adalah mendengarkan musik." }
      ]
    }
  ],
