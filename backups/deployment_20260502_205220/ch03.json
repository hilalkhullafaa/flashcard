  "conversations": [
    {
      "id": "ch03_conv01",
      "chapterId": 3,
      "order": 1,
      "title": "Percakapan 1 â€” Menanyakan Lokasi",
      "turns": [
        {
          "speaker": "ミラー",
          "japanese": "すみません、ゆうびんきょくは どこですか。",
          "romaji": "Sumimasen, yuubinkyoku wa doko desu ka.",
          "indonesian": "Permisi, di mana kantor pos?",
          "hiragana": "すみません、ゆうびんきょくは どこですか。"
        },
        {
          "speaker": "つうこうにん",
          "japanese": "あそこです。あの たてものの となりです。",
          "romaji": "Asoko desu. Ano tatemono no tonari desu.",
          "indonesian": "Di sana. Di sebelah gedung itu.",
          "hiragana": "あそこです。あの たてものの となりです。"
        },
        {
          "speaker": "ミラー",
          "japanese": "ありがとうございます。",
          "romaji": "Arigatou gozaimasu.",
          "indonesian": "Terima kasih.",
          "hiragana": "ありがとうございます。"
        }
      ]
    },
    {
      "id": "ch03_conv02",
      "chapterId": 3,
      "order": 2,
      "title": "Percakapan 2 â€” Di Dalam Toko",
      "turns": [
        {
          "speaker": "てんいん",
          "japanese": "いらっしゃいませ。",
          "romaji": "Irasshaimase.",
          "indonesian": "Selamat datang.",
          "hiragana": "いらっしゃいませ。"
        },
        {
          "speaker": "ミラー",
          "japanese": "すみません、エレベーターは どこですか。",
          "romaji": "Sumimasen, erebeetaa wa doko desu ka.",
          "indonesian": "Permisi, di mana lift?",
          "hiragana": "すみません、エレベーターは どこですか。"
        },
        {
          "speaker": "てんいん",
          "japanese": "あちらです。",
          "romaji": "Achira desu.",
          "indonesian": "Di sana.",
          "hiragana": "あちらです。"
        },
        {
          "speaker": "ミラー",
          "japanese": "この かばんは いくらですか。",
          "romaji": "Kono kaban wa ikura desu ka.",
          "indonesian": "Berapa harga tas ini?",
          "hiragana": "この かばんは いくらですか。"
        },
        {
          "speaker": "てんいん",
          "japanese": "18,000えんです。",
          "romaji": "Ichiman hassenhyaku en desu.",
          "indonesian": "18.000 yen.",
          "hiragana": "18,000えんです。"
        }
      ]
    },
    {
      "id": "ch03_conv03",
      "chapterId": 3,
      "order": 3,
      "title": "Percakapan 3 — Menanyakan Lantai",
      "turns": [
        {
          "speaker": "ミラー",
          "japanese": "すみません、くつうりばは なんがいですか。",
          "romaji": "Sumimasen, kutsu uriba wa nangai desu ka.",
          "indonesian": "Permisi, konter sepatu ada di lantai berapa?",
          "hiragana": "すみません、くつうりばは なんがいですか。"
        },
        {
          "speaker": "てんいん",
          "japanese": "3かいです。",
          "romaji": "Sangai desu.",
          "indonesian": "Lantai 3.",
          "hiragana": "3かいです。"
        },
        {
          "speaker": "ミラー",
          "japanese": "ありがとうございます。",
          "romaji": "Arigatou gozaimasu.",
          "indonesian": "Terima kasih.",
          "hiragana": "ありがとうございます。"
