  "patterns": [
    {
      "id": "ch03_p01",
      "chapterId": 3,
      "order": 1,
      "pattern": "N は どこですか",
      "explanation": "Menanyakan lokasi suatu tempat atau benda. どこ (doko) berarti 'di mana'.",
      "examples": [
        {
          "japanese": "トイレは どこですか。",
          "romaji": "Toire wa doko desu ka.",
          "indonesian": "Di mana toilet?"
        },
        {
          "japanese": "ゆうびんきょくは どこですか。",
          "romaji": "Yuubinkyoku wa doko desu ka.",
          "indonesian": "Di mana kantor pos?"
        }
      ]
    },
    {
      "id": "ch03_p02",
      "chapterId": 3,
      "order": 2,
      "pattern": "N は N の N です",
      "explanation": "Menyatakan posisi relatif suatu tempat atau benda terhadap benda lain menggunakan kata posisi (atas, bawah, depan, dll.).",
      "examples": [
        {
          "japanese": "エレベーターは あちらです。",
          "romaji": "Erebeetaa wa achira desu.",
          "indonesian": "Lift ada di sana."
        },
        {
          "japanese": "コンビニは えきの まえです。",
          "romaji": "Konbini wa eki no mae desu.",
          "indonesian": "Minimarket ada di depan stasiun."
        }
      ]
    },
    {
      "id": "ch03_p03",
      "chapterId": 3,
      "order": 3,
      "pattern": "N に N が あります/います",
      "explanation": "Menyatakan keberadaan benda (あります) atau orang/hewan (います) di suatu tempat. Partikel に menandai lokasi, が menandai subjek.",
      "examples": [
        {
          "japanese": "デパートの となりに ぎんこうが あります。",
          "romaji": "Depaato no tonari ni ginkou ga arimasu.",
          "indonesian": "Ada bank di sebelah department store."
        },
        {
          "japanese": "としょかんの まえに バスていが あります。",
          "romaji": "Toshokan no mae ni basutei ga arimasu.",
          "indonesian": "Ada halte bus di depan perpustakaan."
        }
      ]
    },
    {
      "id": "ch03_p04",
      "chapterId": 3,
      "order": 4,
      "pattern": "N は いくらですか",
      "explanation": "Menanyakan harga suatu barang. いくら (ikura) berarti 'berapa harganya'.",
      "examples": [
        {
          "japanese": "この かばんは いくらですか。",
          "romaji": "Kono kaban wa ikura desu ka.",
          "indonesian": "Berapa harga tas ini?"
        },
        {
          "japanese": "そのとけいは いくらですか。",
          "romaji": "Sono tokei wa ikura desu ka.",
          "indonesian": "Berapa harga jam itu?"
        }
      ]
    }
  ],
  "grammar": [
    {
      "id": "ch03_g01",
      "chapterId": 3,
      "order": 1,
      "title": "Kata Tunjuk Tempat ここ・そこ・あそこ",
      "explanation": "Sistem Ko-So-A-Do juga berlaku untuk lokasi. ここ (koko) berarti 'di sini' (dekat pembicara), そこ (soko) berarti 'di situ' (dekat lawan bicara), あそこ (asoko) berarti 'di sana' (jauh dari keduanya), dan どこ (doko) berarti 'di mana' (pertanyaan). Bentuk sopannya adalah こちら/そちら/あちら/どちら.",
      "examples": [
        {
          "japanese": "トイレは どこですか。— あそこです。",
          "romaji": "Toire wa doko desu ka. â€” Asoko desu.",
          "indonesian": "Di mana toilet? â€” Di sana."
        },
        {
          "japanese": "ここは としょかんです。",
          "romaji": "Koko wa toshokan desu.",
          "indonesian": "Di sini adalah perpustakaan."
        }
      ]
    },
    {
      "id": "ch03_g02",
      "chapterId": 3,
      "order": 2,
      "title": "Kata Posisi (Preposisi Lokasi)",
      "explanation": "Kata posisi seperti うえ (atas), した (bawah), まえ (depan), うしろ (belakang), みぎ (kanan), ひだり (kiri), なか (dalam), そと (luar), となり (sebelah), ちかく (dekat), dan あいだ (antara) digunakan bersama partikel の untuk menyatakan posisi relatif suatu benda terhadap benda lain.",
      "examples": [
        {
          "japanese": "ほんは つくえの うえに あります。",
          "romaji": "Hon wa tsukue no ue ni arimasu.",
          "indonesian": "Buku ada di atas meja."
        },
        {
          "japanese": "コンビニは えきの となりです。",
          "romaji": "Konbini wa eki no tonari desu.",
          "indonesian": "Minimarket ada di sebelah stasiun."
        }
      ]
    },
    {
      "id": "ch03_g03",
      "chapterId": 3,
      "order": 3,
      "title": "Partikel に �?? Keberadaan di Tempat",
      "explanation": "Partikel に (ni) digunakan untuk menandai lokasi keberadaan suatu benda atau orang. Pola dasarnya adalah 'Tempat に Benda/Orang が あります/います'. あります digunakan untuk benda mati, います untuk orang dan hewan.",
      "examples": [
        {
          "japanese": "えきの まえに バスていが あります。",
          "romaji": "Eki no mae ni basutei ga arimasu.",
          "indonesian": "Ada halte bus di depan stasiun."
        },
        {
          "japanese": "としょかんに がくせいが います。",
          "romaji": "Toshokan ni gakusei ga imasu.",
          "indonesian": "Ada pelajar di perpustakaan."
        }
      ]
    }
  ],
