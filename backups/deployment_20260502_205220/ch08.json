  "conversations": [
    {
      "id": "ch08_conv01",
      "chapterId": 8,
      "order": 1,
      "title": "Percakapan 1 — Di Toko Buah",
      "turns": [
        {
          "speaker": "店員",
          "japanese": "いらっしゃいませ。",
          "romaji": "Irasshaimase.",
          "indonesian": "Selamat datang.",
          "hiragana": "いらっしゃいませ。"
        },
        {
          "speaker": "ミラー",
          "japanese": "りんごを みっつ ください。",
          "romaji": "Ringo o mittsu kudasai.",
          "indonesian": "Tolong tiga buah apel.",
          "hiragana": "りんごを みっつ ください。"
        },
        {
          "speaker": "店員",
          "japanese": "はい。ほかに なにか。",
          "romaji": "Hai. Hoka ni nanika?",
          "indonesian": "Baik. Ada yang lain?",
          "hiragana": "はい。ほかに なにか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "牛乳を 1本 おねがいします。全部で いくらですか。",
          "romaji": "Gyuunyuu o ippon onegai shimasu. Zenbu de ikura desu ka.",
          "indonesian": "Satu botol susu juga. Semuanya berapa?",
          "hiragana": "ぎゅうにゅうを 1ぽん おねがいします。ぜんぶで いくらですか。"
        },
        {
          "speaker": "店員",
          "japanese": "580円です。",
          "romaji": "Gohyaku hachijuu en desu.",
          "indonesian": "580 yen.",
          "hiragana": "580えんです。"
        }
      ]
    },
    {
      "id": "ch08_conv02",
      "chapterId": 8,
      "order": 2,
      "title": "Percakapan 2 — Menanyakan Jumlah",
      "turns": [
        {
          "speaker": "カリナ",
          "japanese": "猫が 何匹 いますか。",
          "romaji": "Neko ga nanbiki imasu ka.",
          "indonesian": "Ada berapa ekor kucing?",
          "hiragana": "ねこが なんびき いますか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "3匹 います。",
          "romaji": "Sanbiki imasu.",
          "indonesian": "Ada 3 ekor.",
          "hiragana": "3びき います。"
        },
        {
          "speaker": "カリナ",
          "japanese": "かわいいですね。犬は いますか。",
          "romaji": "Kawaii desu ne. Inu wa imasu ka.",
          "indonesian": "Lucu ya. Ada anjing?",
          "hiragana": "かわいいですね。いぬは いますか。"
        },
        {
          "speaker": "ミラー",
          "japanese": "いいえ、いません。",
          "romaji": "Iie, imasen.",
          "indonesian": "Tidak ada.",
          "hiragana": "いいえ、いません。"
        }
      ]
    },
    {
      "id": "ch08_conv03",
      "chapterId": 8,
      "order": 3,
      "title": "Percakapan 3 — Kota yang Ramai",
      "turns": [
        {
          "speaker": "ミラー",
          "japanese": "東京は どんな 町ですか。",
          "romaji": "Toukyou wa donna machi desu ka.",
          "indonesian": "Tokyo kota seperti apa?",
          "hiragana": "とうきょうは どんな まちですか。"
        },
        {
          "speaker": "やまだ",
          "japanese": "にぎやかな 町です。",
          "romaji": "Nigiyaka na machi desu.",
          "indonesian": "Kota yang ramai.",
          "hiragana": "にぎやかな まちです。"
        }
      ]
    },
    {
      "id": "ch08_conv04",
      "chapterId": 8,
      "order": 4,
      "title": "Percakapan 4 — Tempat yang Tenang",
      "turns": [
